var _autoDispatchTimer = null;
function scheduleHydroDispatch() {
    if (window._URL_OFFICE_ID && !isWpodAuthenticated) return;   // URL offices need auth
    if (!window._URL_OFFICE_ID && !isWpodAuthenticated) return;  // default NWC also needs auth
    if (!customFrameConfig.dispatchToken) return;  // no token yet
    if (customFrameConfig.nwcOpsLevel === 'Level 4' &&
        customFrameConfig.officeId !== 'NWCO' &&
        customFrameConfig.profile  !== 'NWC') return;  // non-NWC offices skip Level 4 auto-dispatch
    clearTimeout(_autoDispatchTimer);
    _autoDispatchTimer = setTimeout(function() {
        writeHydroStatus(function(ok) {
            var el = document.getElementById('nwc-update-status');
            if (el) { el.innerText = ok ? '✓ Auto-saved' : '✗ Auto-save failed'; setTimeout(function(){ if(el) el.innerText=''; }, 3000); }
        });
    }, 2000);
}
