// Schedule fetches at :02 and :32 past each hour to catch GitHub Action output
function scheduleNCOFetch() {
    var now = new Date();
    var minutes = now.getMinutes();
    var seconds = now.getSeconds();
    // Fire at :02, :12, :22, :32, :42, :52 (2 min after each 10-min action run)
    var targets = [2, 12, 22, 32, 42, 52, 62];
    var nextTarget = targets.find(function(t){ return t > minutes; }) || 62;
    var msUntilNext = ((nextTarget - minutes) * 60 - seconds) * 1000;
    setTimeout(function() {
        fetchLiveNCOStatus();
        setInterval(fetchLiveNCOStatus, 600000);
    }, msUntilNext);
}
scheduleNCOFetch();

// ── LIVE STATUS JSON POLLING ──────────────────────────────────────────────────
// Polls the status JSON every 2 minutes — updates ops level banner, reason,
// hours, and status panel without requiring a page reload.
var _lastStatusHash = '';

function pollStatusJSON() {
    if (!window._URL_OFFICE_ID && !window._DEFAULT_MODE) return;
    var officeKey = customFrameConfig.officeJsonKey || 'nwc';

    fetch(currentStatusFileURL() + '?cb=' + Date.now())
        .then(function(r){ return r.ok ? r.text() : null; })
        .then(function(text) {
            if (!text) return;
            // Only process if content actually changed
            if (text === _lastStatusHash) return;
            _lastStatusHash = text;

            var data;
            try { data = JSON.parse(text); }
            catch(e) { return; }  // silently ignore corrupt JSON during polling

            var officeData = data[officeKey];
            if (!officeData) return;

            // Don't overwrite if user is actively editing (authenticated and modal open)
            var modalOpen = document.getElementById('settings-modal') &&
                            document.getElementById('settings-modal').style.display !== 'none';
            if (isWpodAuthenticated && modalOpen) return;

            // Update ops level if not authenticated (read-only update)
            if (!isWpodAuthenticated) {
                var newLevel = officeData.opsLevel || 'Level 4 (Normal Operations)';
                var newReason = officeData.reason || '';
                var newHours  = officeData.hours  || '';

                // Map full string back to key
                var levelKey = Object.keys(LEVEL_NAMES).find(function(k){ return LEVEL_NAMES[k] === newLevel; }) || 'Level 4';
                customFrameConfig.nwcOpsLevel  = levelKey;
                customFrameConfig.nwcOpsReason = newReason;
                customFrameConfig.nwcOpsHours  = newHours;

                applyNWCOpsLevelUI();

                // Update ops reason text in header bar if visible
                var reasonEl = document.getElementById('nwc-ops-reason-display');
                if (reasonEl) reasonEl.innerText = newReason;

                // Refresh status panel if in Status mode
                refreshStatusPanelIfActive();

                // Flash sync dot to show data updated
                var dot = document.getElementById('sync-dot');
                if (dot) {
                    dot.className = 'sync-dot synced';
                    var txt = document.getElementById('sync-text');
                    if (txt) txt.innerText = 'UPDATED';
                    setTimeout(function(){
                        if (txt) txt.innerText = 'SYNCED';
                    }, 3000);
                }
            }
        })
        .catch(function(){ /* silent — polling errors are non-fatal */ });
}

// Start polling 30s after page load, then every 2 minutes
setTimeout(function(){
    pollStatusJSON();
    setInterval(pollStatusJSON, 120000);
}, 30000);
// ── END LIVE STATUS JSON POLLING ──────────────────────────────────────────────

        // ── LIVE STATUS POLLING ───────────────────────────────────────────────
        // Polls every 60s. Re-applies only when lastUpdated changes.
        var _lastKnownUpdated = null;

        function applyHydroStatusData(data) {
            if (!data) return;
            var officeKey = customFrameConfig.officeJsonKey || 'nwc';
            var lsPrefix  = customFrameConfig.officeId || 'NWCO';
            var officeData = data[officeKey];
            if (!officeData) return;

            // Ops Level + Reason → NWC banner updates live
            if (officeData.opsLevel) {
                var lvlKey = 'Level 4';
                if (officeData.opsLevel.indexOf('Level 1') !== -1) lvlKey = 'Level 1';
                else if (officeData.opsLevel.indexOf('Level 2') !== -1) lvlKey = 'Level 2';
                else if (officeData.opsLevel.indexOf('Level 3') !== -1) lvlKey = 'Level 3';
                customFrameConfig.nwcOpsLevel  = lvlKey;
                customFrameConfig.nwcOpsReason = officeData.reason || '';
                if (officeData.hours && officeData.hours !== 'See schedule')
                    customFrameConfig.nwcOpsHours = officeData.hours;
                applyNWCOpsLevelUI();
            }

            // Preferences (hero zones, visible zones, display name, marker positions, etc.)
            if (officeData.preferences) applyOfficePreferences(officeData.preferences);

            // Roster — seed from server only if nothing local
            var rosterKey = lsPrefix + '_ROSTER';
            var lr = []; try { lr = JSON.parse(localStorage.getItem(rosterKey) || '[]'); } catch(e) {}
            if (!lr.length && officeData.roster && officeData.roster.length)
                try { localStorage.setItem(rosterKey, JSON.stringify(officeData.roster)); } catch(e) {}

            // Shifts — seed from server only if nothing local
            var shiftsKey = lsPrefix + '_SHIFTS';
            var ls = null; try { ls = JSON.parse(localStorage.getItem(shiftsKey)); } catch(e) {}
            var hasLocalShifts = ls && ls.some(function(s){ return s.lead || (s.forecasters && s.forecasters.length); });
            if (!hasLocalShifts && officeData.shifts && officeData.shifts.some(function(s){ return s.lead || (s.forecasters && s.forecasters.length); }))
                try { localStorage.setItem(shiftsKey, JSON.stringify(officeData.shifts)); } catch(e) {}

            // FIM/IC — seed from server only if nothing local
            var fimKey = lsPrefix + '_FIMIC';
            var lf = {}; try { lf = JSON.parse(localStorage.getItem(fimKey) || '{}'); } catch(e) {}
            if (!lf.fimName && officeData.fim && officeData.fim.name)
                try { localStorage.setItem(fimKey, JSON.stringify({
                    fimName: officeData.fim.name, fimStart: officeData.fim.start || '',
                    fimEnd: officeData.fim.end || '',
                    icName:  officeData.ic ? (officeData.ic.name  || '') : '',
                    icStart: officeData.ic ? (officeData.ic.start || '') : '',
                    icEnd:   officeData.ic ? (officeData.ic.end   || '') : ''
                })); } catch(e) {}

            // Tomorrow/Day3/Day4 shifts — seed if nothing local
            [['_TOMORROW_SHIFTS','tomorrow'],['_DAY3_SHIFTS','day3'],['_DAY4_SHIFTS','day4']].forEach(function(pair){
                var k = lsPrefix + pair[0]; var field = pair[1];
                var loc = []; try { loc = JSON.parse(localStorage.getItem(k) || '[]'); } catch(e) {}
                if (!loc.length && officeData[field] && officeData[field].length)
                    try { localStorage.setItem(k, JSON.stringify(officeData[field])); } catch(e) {}
            });

            // Forecast — seed if nothing local
            if (officeData.forecast) {
                var fk = lsPrefix + '_FORECAST';
                var lfc = {}; try { lfc = JSON.parse(localStorage.getItem(fk) || '{}'); } catch(e) {}
                if (!Object.keys(lfc).length) try { localStorage.setItem(fk, JSON.stringify(officeData.forecast)); } catch(e) {}
            }

            // Backup — seed if nothing local
            if (officeData.backup) {
                var bk = lsPrefix + '_BACKUP';
                var lb = null; try { lb = JSON.parse(localStorage.getItem(bk)); } catch(e) {}
                if (!lb) try { localStorage.setItem(bk, JSON.stringify(officeData.backup)); } catch(e) {}
            }

            // Slack template — seed if nothing local
            if (officeData.preferences && officeData.preferences.slackTemplate) {
                var sk = lsPrefix + '_SLACK_TEMPLATE';
                if (!localStorage.getItem(sk))
                    try { localStorage.setItem(sk, officeData.preferences.slackTemplate); } catch(e) {}
            }

            // Update status panel + sync dot
            if (window._STATUS_MODE) refreshStatusPanelIfActive();
            var dot  = document.getElementById('sync-dot');
            var stxt = document.getElementById('sync-text');
            if (dot)  { dot.style.background = '#2ea84a'; dot.style.animation = ''; }
            if (stxt) { stxt.innerText = 'SYNCED'; stxt.style.color = ''; }
        }

        function pollHydroStatus() {
            fetch(currentStatusFileURL() + '?cb=' + Date.now())
                .then(function(r){ if (!r.ok) throw new Error('HTTP ' + r.status); return r.text(); })
                .then(function(text) {
                    try { return JSON.parse(text); }
                    catch(e) { showJSONCorruptWarning(currentStatusFileURL()); return null; }
                })
                .then(function(data) {
                    if (!data) return;
                    var ts = data.lastUpdated || '';
                    // First load: always apply. After: only when server data changed.
                    if (_lastKnownUpdated === null || ts !== _lastKnownUpdated) {
                        _lastKnownUpdated = ts;
                        applyHydroStatusData(data);
                        if (ts && _lastKnownUpdated !== null) console.log('Status updated from server:', ts);
                    }
                })
                .catch(function(e){ console.log('hydro-status poll failed:', e); });
        }

        pollHydroStatus();
        setInterval(pollHydroStatus, 60000);  // re-check every 60s
        // ── END LIVE STATUS POLLING ────────────────────────────────────────────

applyNWCOpsLevelUI();

setInterval(update, 1000);
update();

// Apply URL-driven office LAST — after all zones, selectors, and init are fully ready
if (window._DEFAULT_MODE) {
    applyDefaultMode();
} else {
    applyURLOffice();
}
</script>
<!-- Hidden home station inputs — kept for JS compatibility but section removed from UI -->
<input type="hidden" id="home-lat-input" value="">
<input type="hidden" id="home-lng-input" value="">
<select id="home-tz-selector" style="display:none;"></select>
<!-- ── CLOCK PICKER ──────────────────────────────────────────────────────── -->
<div id="clock-picker-overlay" onclick="closeClockPicker()"></div>
<div id="clock-picker">
    <div class="clock-mode-label" id="clock-picker-mode-label">SELECT HOUR</div>
    <div id="clock-time-display">12:00 AM</div>
    <div class="clock-ampm-row">
        <button class="clock-ampm-btn active" id="clock-am-btn" onclick="setClockAMPM('AM')">AM</button>
        <button class="clock-ampm-btn" id="clock-pm-btn" onclick="setClockAMPM('PM')">PM</button>
    </div>
    <div class="clock-face" id="clock-face" onclick="handleClockFaceClick(event)">
        <div class="clock-hand" id="clock-hour-hand" style="width:3px;height:52px;background:#58c4f5;margin-left:-1.5px;"></div>
        <div class="clock-hand" id="clock-min-hand"  style="width:2px;height:62px;background:#2ea84a; margin-left:-1px; display:none;"></div>
        <div class="clock-center"></div>
    </div>
    <div style="display:flex;gap:8px;width:100%;">
        <button onclick="closeClockPicker()" style="flex:1;padding:6px;border:1px solid #444;background:transparent;color:#8b949e;border-radius:5px;cursor:pointer;font-size:0.8rem;">Cancel</button>
        <button onclick="applyClockPicker()" style="flex:1;padding:6px;border:1px solid #1e7ead;background:#1a4e6e;color:#fff;border-radius:5px;cursor:pointer;font-size:0.8rem;font-weight:700;">Apply</button>
    </div>
</div>
<!-- ── END CLOCK PICKER ───────────────────────────────────────────────────── -->

</body>
</html>
