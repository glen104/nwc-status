function initSelectors() {
    const selectorTiers = [document.getElementById('hero-1'), document.getElementById('hero-2'), document.getElementById('hero-3')];
    selectorTiers.forEach((sel, i) => {
        if (!sel) return;
        const previousSelectionValue = activeHeroZones[i] || 'none';
        sel.innerHTML = '<option value="none">None</option>';
        zoneOrder.forEach(zKey => {
            if (visibleTimeZones.includes(zKey)) {
                const opt = document.createElement('option');
                opt.value = zKey; opt.innerText = zoneNames[zKey]; sel.appendChild(opt);
            }
        });
        sel.value = visibleTimeZones.includes(previousSelectionValue) ? previousSelectionValue : 'none';
    });

    const homeTzSelectorNode = document.getElementById('home-tz-selector');
    if (homeTzSelectorNode) {
        const cachedHomeSelection = customFrameConfig.homeTZ || 'none';
        homeTzSelectorNode.innerHTML = '<option value="none">Select Home Station Time Zone Designation</option>';
        zoneOrder.forEach(zKey => {
            if (visibleTimeZones.includes(zKey)) {
                const opt = document.createElement('option');
                opt.value = zKey; opt.innerText = zoneNames[zKey]; homeTzSelectorNode.appendChild(opt);
            }
        });
        homeTzSelectorNode.value = visibleTimeZones.includes(cachedHomeSelection) ? cachedHomeSelection : 'none';
    }
}

function getHeroColor(id) {
    const idx = activeHeroZones.indexOf(id);
    if (idx === 0) return 'var(--color-slot-1)';
    if (idx === 1) return 'var(--color-slot-2)';
    if (idx === 2) return 'var(--color-slot-3)';
    return 'var(--color-default)';
}

function renderHero() {
    const container = document.getElementById('hero-container');
    activeHeroZones = [document.getElementById('hero-1').value, document.getElementById('hero-2').value, document.getElementById('hero-3').value].filter(z => z !== 'none');
    if (!container) return;
    container.style.gridTemplateColumns = `repeat(${activeHeroZones.length}, 1fr)`;
    
    let html = '';
    activeHeroZones.forEach((id, index) => {
        const color = `var(--color-slot-${index + 1})`;
        html += `<div class="card" style="border-top-color: ${color};">
                    <div class="label-mini" style="color: ${color};">${zoneNames[id]}</div>
                    <div class="big-time" id="hero-${id}-t" style="color: ${color};">--:--:--</div>
                 </div>`;
    });
    container.innerHTML = html;
    
    document.querySelectorAll('.tab').forEach(tab => { tab.style.borderBottomColor = 'transparent'; });
    activeHeroZones.forEach(id => {
        const footTab = document.querySelector(`.tab.f-${id}`);
        if (footTab) footTab.style.borderBottomColor = getHeroColor(id);
    });

    saveSettings();
    update();
}

