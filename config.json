// ── URL-BASED OFFICE ROUTING ──────────────────────────────────────────────────
// Supports: ?OHRFC  or  ?profile=OHRFC  (case-insensitive)
(function parseOfficeFromURL() {
    const params = new URLSearchParams(window.location.search);
    let found = null;
    let statusMode = false;
    let forcePCMode = false;
    let forceSDMode = false;

    if (params.has('profile')) {
        found = params.get('profile').toUpperCase();
    } else {
        for (let key of params.keys()) {
            var upper = key.toUpperCase();
            // ?OHRFC-Status
            var statusMatch = upper.match(/^([A-Z]+)-STATUS$/);
            if (statusMatch && OFFICE_CONFIGS[statusMatch[1]]) { found = statusMatch[1]; statusMode = true; break; }
            // ?OHRFC-PC
            var pcMatch = upper.match(/^([A-Z]+)-PC$/);
            if (pcMatch && OFFICE_CONFIGS[pcMatch[1]]) { found = pcMatch[1]; forcePCMode = true; break; }
            // ?OHRFC-SD
            var sdMatch = upper.match(/^([A-Z]+)-SD$/);
            if (sdMatch && OFFICE_CONFIGS[sdMatch[1]]) { found = sdMatch[1]; forceSDMode = true; break; }
            // ?OHRFC
            if (OFFICE_CONFIGS[upper]) { found = upper; break; }
        }
    }
    window._URL_OFFICE_ID  = (found && OFFICE_CONFIGS[found]) ? found : null;
    window._STATUS_MODE    = statusMode && !!window._URL_OFFICE_ID;
    window._FORCE_PC_MODE  = forcePCMode && !!window._URL_OFFICE_ID;
    window._FORCE_SD_MODE  = forceSDMode && !!window._URL_OFFICE_ID;
    window._DEFAULT_MODE   = !window._URL_OFFICE_ID;
})();
// ── END URL ROUTING ───────────────────────────────────────────────────────────

