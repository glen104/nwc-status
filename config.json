    const visualHeaderLabel = document.getElementById('header-profile-title');

    const secureAuthBlock = document.getElementById('wpod-auth-gate');
    const secureControlsBlock = document.getElementById('nwc-secure-controls');
    const stdNwcHeaderNode = document.getElementById('nwc-ops-level-container');
    const ncoNwcHeaderNode = document.getElementById('nco-nwc-ops-level-container');

    // Reset auth on profile change
    if (!isWpodAuthenticated) {
        document.getElementById('wpod-password-input').value = "";
    }

    // Show auth gate for: any URL-locked office, any office with a loaded token,
    // OR the default NWC/WPOD profile — but NOT default mode
    var officeHasToken = !window._DEFAULT_MODE && (!!encryptedDispatchToken || window._URL_OFFICE_ID || customFrameConfig.profile === 'NWC');
    var showAuthGate = officeHasToken && !isWpodAuthenticated;

    // Update auth label for current office
    var authLabel = document.getElementById('office-auth-label');
    if (authLabel) {
        var oid = customFrameConfig.officeId;
        var ocfg = OFFICE_CONFIGS[oid];
        var officeName = ocfg ? ocfg.name : 'Office';
        authLabel.innerText = officeName + ' — Security Key Required:';
    }

    // NWC ops level header — show for NWC profile or URL-locked NWC office only, NOT all URL offices
    var showOpsHeader = (customFrameConfig.profile === "NWC") && !window._DEFAULT_MODE;
    [stdNwcHeaderNode, ncoNwcHeaderNode].forEach(function(node) {
        if (node) node.style.display = showOpsHeader ? "flex" : "none";
    });

    if (showAuthGate) {
        secureAuthBlock.style.display = "flex";
        secureControlsBlock.style.display = "none";
    } else if (isWpodAuthenticated) {
        secureAuthBlock.style.display = "none";
        secureControlsBlock.style.display = "flex";
    } else {
        secureAuthBlock.style.display = "none";
        secureControlsBlock.style.display = "none";
    }

    const stationInput = document.getElementById('station-identifier');
    if (customFrameConfig.profile === "WFO") {
        if (nodeInputContainer) nodeInputContainer.style.display = "flex";
        if (nodeLabelElement) nodeLabelElement.innerText = "WFO Name:";
        if (stationInput) stationInput.placeholder = "e.g. Lubbock";
    } else if (customFrameConfig.profile === "RFC" || customFrameConfig.profile === "RFC_OWP") {
        if (nodeInputContainer) nodeInputContainer.style.display = "flex";
        if (nodeLabelElement) nodeLabelElement.innerText = "RFC Display Name:";
        if (stationInput) stationInput.placeholder = "e.g. Ohio  (optional — defaults to code)";
    } else {
        if (nodeInputContainer) nodeInputContainer.style.display = "none";
        customFrameConfig.nodeIdentifier = "";
    }

    // NCO status bar — show for all modes except URL-locked non-NWC offices that don't need it
    var ncoStatusContainer = document.getElementById('nco-status-container');
    if (ncoStatusContainer) ncoStatusContainer.style.display = 'flex';

    const standardHeader = document.getElementById('standard-header');
    const ncoBannerElement = document.getElementById('nco-header-banner');
    const owpLogoGraphic = document.getElementById('owp-main-logo');

    if (customFrameConfig.profile === "NCO") {
        if (standardHeader) standardHeader.style.display = "none";
        if (ncoBannerElement) ncoBannerElement.style.display = "flex";
        if (systemFaviconEl) systemFaviconEl.href = "https://www.weather.gov/favicon.ico";
        document.title = "NCO Time Zones";
        if (visualHeaderLabel) visualHeaderLabel.style.display = "none";
    } else {
        if (ncoBannerElement) ncoBannerElement.style.display = "none";
        if (standardHeader) standardHeader.style.display = "block";
        
        const isOwpBranded = (customFrameConfig.profile === "OWP" || customFrameConfig.profile === "NWC" || customFrameConfig.profile === "RFC_OWP");
        
        if (owpLogoGraphic) owpLogoGraphic.style.display = (isOwpBranded && owpLogoVisible) ? "block" : "none";
        if (systemFaviconEl) systemFaviconEl.href = isOwpBranded ? "https://avatars.githubusercontent.com/u/60660814?s=280&v=4" : "https://www.weather.gov/favicon.ico";

        // Build display string: URL offices use canonical name, default mode uses nodeIdentifier
        var _ocfg_hpc = OFFICE_CONFIGS[customFrameConfig.officeId];
        var calculatedDisplayString = "";
        if (window._URL_OFFICE_ID && _ocfg_hpc) {
            switch (customFrameConfig.profile) {
                case 'NWC':     calculatedDisplayString = 'NWC OPERATIONS'; break;
                case 'OWP':     calculatedDisplayString = ''; break;
                case 'RFC':
                case 'RFC_OWP': calculatedDisplayString = customFrameConfig.nodeIdentifier || customFrameConfig.officeId; break;
                case 'WFO':     calculatedDisplayString = 'WFO ' + (customFrameConfig.nodeIdentifier || customFrameConfig.officeId); break;
                default:        calculatedDisplayString = _ocfg_hpc.name || '';
            }
        } else {
            var _nodeId = customFrameConfig.nodeIdentifier || '';
            switch (customFrameConfig.profile) {
                case 'OWP':     calculatedDisplayString = ''; break;
                case 'NWC':     calculatedDisplayString = 'NWC OPERATIONS'; break;
                case 'WFO':     calculatedDisplayString = _nodeId ? 'WFO ' + _nodeId : 'WFO'; break;
                case 'RFC':
                case 'RFC_OWP': calculatedDisplayString = _nodeId ? _nodeId + ' RFC' : 'RFC'; break;
                default:        calculatedDisplayString = _nodeId;
            }
        }
        document.title = calculatedDisplayString ? calculatedDisplayString + ' — NWS Time Zones' : 'NWS Time Zones';

        if (visualHeaderLabel) {
            if (calculatedDisplayString) {
                visualHeaderLabel.innerText = calculatedDisplayString;
                visualHeaderLabel.style.display = "inline-block";
                visualHeaderLabel.style.marginLeft = isOwpBranded ? "26px" : "15px"; 
            } else {
                visualHeaderLabel.style.display = "none";
            }
        }
    }

    saveSettings();
    renderHero();
}

function handleIdentifierInput() {
    customFrameConfig.nodeIdentifier = document.getElementById('station-identifier').value; 
    handleProfileChange();
}

function handleSecondsToggle() {
    customFrameConfig.showSeconds = document.getElementById('seconds-toggle').checked;
    saveSettings();
    update();
}

function changeSlotColor(slotIndex, pickerElement) {
    customFrameConfig.slotColors[slotIndex - 1] = pickerElement.value;
    document.documentElement.style.setProperty(`--color-slot-${slotIndex}`, pickerElement.value);
    saveSettings();
    renderHero();
}

function syncFormatToggles(element) {
    use24Hour = element.checked;
    saveSettings();
    update();
}

function handleHeroSelectorChange() {
    activeHeroZones = [document.getElementById('hero-1').value, document.getElementById('hero-2').value, document.getElementById('hero-3').value];
    renderHero();
}

function saveSettings() {
    // URL-locked offices don't overwrite localStorage — those settings belong to the user's own profile
    if (window._URL_OFFICE_ID) return;
    try {
        if (!map || typeof map.getZoom !== 'function') return;
        const settings = {
            heroZones: [document.getElementById('hero-1').value, document.getElementById('hero-2').value, document.getElementById('hero-3').value],
            use24Hour: use24Hour,
            isPCMode: isPCMode,
            owpLogoVisible: owpLogoVisible,
            zoom: map.getZoom(),
            center: [map.getCenter().lat, map.getCenter().lng],
            
            profile: customFrameConfig.profile,
            nodeIdentifier: customFrameConfig.nodeIdentifier,
            showSeconds: customFrameConfig.showSeconds,
            slotColors: customFrameConfig.slotColors,
            homeGPS: customFrameConfig.homeGPS,
            homeTZ: customFrameConfig.homeTZ,
            visibleTimeZones: visibleTimeZones,
            ncoStatus: customFrameConfig.ncoStatus,
            nwcOpsLevel: customFrameConfig.nwcOpsLevel,
            // dispatchToken not saved - decrypted in memory only
            nwcOpsReason: customFrameConfig.nwcOpsReason,
            nwcOpsHours: customFrameConfig.nwcOpsHours,
            nwcOpsOpen:  customFrameConfig.nwcOpsOpen,
            nwcOpsClose: customFrameConfig.nwcOpsClose
        };
        localStorage.setItem('owp_operational_v20', JSON.stringify(settings));
    } catch(e) {}
}

function manualSave() {
    if (window._DEFAULT_MODE) { saveSettings(); alert('Configuration cached locally.'); return; }
    // If URL-locked office, require password before saving
    if (window._URL_OFFICE_ID) {
        var pwd = prompt('Enter your office password to save configuration:');
        if (pwd === null) return; // cancelled
        var expected = getOfficePassword(customFrameConfig.officeId);
        if (pwd.trim() !== expected) {
            alert('Incorrect password — configuration not saved.');
            return;
        }
    }
    saveSettings();

    // Also dispatch preferences to server if we have a token
    var token = customFrameConfig.dispatchToken;
    if (token && window._URL_OFFICE_ID) {
        var hero1 = document.getElementById('hero-1');
        var hero1 = document.getElementById('hero-1');
        var hero2 = document.getElementById('hero-2');
        var hero3 = document.getElementById('hero-3');
        var heroZones = [
            hero1 ? hero1.value : '',
            hero2 ? hero2.value : '',
            hero3 ? hero3.value : ''
        ].filter(function(z){ return z && z !== 'none'; });

        var ocfg = OFFICE_CONFIGS[customFrameConfig.officeId];
        var _otype = currentOfficeType();
        var _msPayload = {
                    officeId: customFrameConfig.officeId,
                    opsLevel: LEVEL_NAMES[customFrameConfig.nwcOpsLevel] || 'Level 4 (Normal Operations)',
                    reason: customFrameConfig.nwcOpsReason || '',
                    hours: getHoursString(),
                    staffing: getStaffingPayload(),
                    tomorrow: getTomorrowStaffingPayload(),
                    roster: getRoster(),
                    preferences: {
                        displayName:    customFrameConfig.nodeIdentifier || '',
                        defaultHours:   ocfg ? ocfg.defaultHours : getHoursString(),
                        heroZones:      heroZones,
                        visibleZones:   visibleTimeZones,
                        slotColors:     customFrameConfig.slotColors,
                        use24Hour:      use24Hour,
                        showSeconds:    customFrameConfig.showSeconds,
                        homeGPS:        customFrameConfig.homeGPS,
                        homeTZ:         customFrameConfig.homeTZ,
                        markerPositions: getMarkerPositions('sd'),
                        slackTemplate:   getSlackTemplate()
                    }
                };
        // WFO gets extra days, backup, forecast
        if (_otype === 'wfo') {
            _msPayload.day3    = getDay3Shifts();
            _msPayload.day4    = getDay4Shifts();
            _msPayload.backup  = getBackupData();
            _msPayload.forecast = getForecastPayload();
        }
        // Non-NWC get shift types
        if (_otype !== 'nwc') _msPayload.shiftTypes = getCustomShiftTypes();

        fetch('https://api.github.com/repos/glen104/nwc-status-private/dispatches', {
            method: 'POST',
            headers: { 'Authorization': 'token ' + token, 'Accept': 'application/vnd.github.v3+json', 'Content-Type': 'application/json' },
            body: JSON.stringify({ event_type: 'hydro_status_update', client_payload: _msPayload })
        })
        .then(function(r){
            alert(r.status === 204 ? 'Configuration saved locally and to server.' : 'Saved locally. Server sync failed (' + r.status + ').');
        })
        .catch(function(){ alert('Saved locally. Server sync unavailable.'); });
    } else {
        alert('Configuration cached locally.');
    }
}

// ── NWC STAFFING ──────────────────────────────────────────────────────────────

// Default shifts
var DEFAULT_SHIFTS = [
    { start: "05:00 AM", end: "01:00 PM", lead: "", forecaster: "" },
    { start: "12:30 PM", end: "08:30 PM", lead: "", forecaster: "" }
];

function _lsPrefix() { return customFrameConfig.officeId || 'NWCO'; }

function getRoster() {
    try { return JSON.parse(localStorage.getItem(_lsPrefix() + '_ROSTER') || '[]'); } catch(e) { return []; }
}

function saveRoster(roster) {
    try { localStorage.setItem(_lsPrefix() + '_ROSTER', JSON.stringify(roster)); } catch(e) {}
}

function getShifts() {
    try { return JSON.parse(localStorage.getItem(_lsPrefix() + '_SHIFTS') || 'null') || JSON.parse(JSON.stringify(DEFAULT_SHIFTS)); } catch(e) { return JSON.parse(JSON.stringify(DEFAULT_SHIFTS)); }
}

function saveShifts(shifts) {
    try { localStorage.setItem(_lsPrefix() + '_SHIFTS', JSON.stringify(shifts)); } catch(e) {}
}

function getFIMIC() {
    try { return JSON.parse(localStorage.getItem(_lsPrefix() + '_FIMIC') || '{}'); } catch(e) { return {}; }
}

function saveFIMIC(data) {
    try { localStorage.setItem(_lsPrefix() + '_FIMIC', JSON.stringify(data)); } catch(e) {}
}

function toggleStaffMgmt() {
    var body = document.getElementById('staff-mgmt-body');
    var btn  = document.getElementById('staff-mgmt-toggle');
    if (!body) return;
    var open = body.style.display !== 'none';
    body.style.display = open ? 'none' : 'flex';
    if (btn) btn.innerText = open ? '▼ Manage' : '▲ Close';
    if (!open) syncRosterAddUI();
}

// ── ROSTER: RFC ROLES ──────────────────────────────────────────────────────────
var RFC_ROLES = ['Lead Hydro', 'Hydro', 'Lead HAS', 'HAS'];
var RFC_ROLE_SECTIONS = [
    { label: 'LEAD HYDRO',  key: 'Lead Hydro' },
    { label: 'HYDRO',       key: 'Hydro' },
    { label: 'LEAD HAS',    key: 'Lead HAS' },
    { label: 'HAS',         key: 'HAS' },
];
var NWC_ROLE_SECTIONS = [
    { label: 'SHIFT LEAD',      key: 'Shift Lead' },
    { label: 'FIM COORDINATOR', key: 'FIM Coordinator' },
    { label: 'IC ELIGIBLE',     key: 'IC' },
    { label: 'FORECASTER',      key: 'Forecaster' },
];

// Show the correct roster add UI based on office type
function syncRosterAddUI() {
    var isRFC = currentOfficeType() === 'rfc';
    var nwcRow = document.getElementById('roster-add-nwc');
    var rfcRow = document.getElementById('roster-add-rfc');
    if (nwcRow) nwcRow.style.display = isRFC ? 'none' : 'flex';
    if (rfcRow) rfcRow.style.display = isRFC ? 'flex' : 'none';
}

function addRosterMember() {
    var name = document.getElementById('nwc-roster-add-name').value.trim();
    var role = document.getElementById('nwc-roster-add-role').value;
    if (!name) return;
    var roster = getRoster();
    var existing = roster.find(function(r){ return r.name === name; });
    if (existing) {
        if (!existing.roles) existing.roles = [existing.role || 'Forecaster'];
        if (existing.roles.indexOf(role) === -1) {
            existing.roles.push(role);
            saveRoster(roster);
            document.getElementById('nwc-roster-add-name').value = '';
            renderRoster();
            updateStaffingDropdowns();
        } else { alert(name + " already has the " + role + " role."); }
        return;
    }
    roster.push({ name: name, roles: [role], role: role });
    saveRoster(roster);
    document.getElementById('nwc-roster-add-name').value = '';
    renderRoster();
    updateStaffingDropdowns();
}

function addRFCRosterMember() {
    var name  = document.getElementById('rfc-roster-add-name').value.trim();
    var role  = document.getElementById('rfc-roster-add-role').value;
    var basin = document.getElementById('rfc-roster-add-basin').value.trim();
    var fim   = document.getElementById('rfc-roster-add-fim').checked;
    if (!name) return;
    var roster = getRoster();
    var existing = roster.find(function(r){ return r.name === name; });
    if (existing) {
        // Update basin/fim if re-adding
        if (basin) existing.basin = basin;
        existing.fim = fim;
        if (!existing.roles) existing.roles = [role];
        else if (existing.roles.indexOf(role) === -1) existing.roles.push(role);
    } else {
        var entry = { name: name, roles: [role], role: role };
        if (basin) entry.basin = basin;
        if (fim)   entry.fim   = true;
        roster.push(entry);
    }
    saveRoster(roster);
    document.getElementById('rfc-roster-add-name').value  = '';
    document.getElementById('rfc-roster-add-basin').value = '';
    document.getElementById('rfc-roster-add-fim').checked = false;
    renderRoster();
    updateStaffingDropdowns();
}

function removeRosterMember(name) {
    if (!confirm('Remove ' + name + ' from roster?')) return;
    var roster = getRoster().filter(function(r){ return r.name !== name; });
    saveRoster(roster);
    renderRoster();
    updateStaffingDropdowns();
}

function renderRoster() {
    var roster = getRoster();
    roster.forEach(function(r){ if (!r.roles) r.roles = [r.role || 'Forecaster']; });
    var el = document.getElementById('nwc-roster-list');
    if (!el) return;
    el.innerHTML = '';
    var isRFC = currentOfficeType() === 'rfc';
    var sections = isRFC ? RFC_ROLE_SECTIONS : NWC_ROLE_SECTIONS;

    sections.forEach(function(sec) {
        var members = roster.filter(function(r){ return r.roles.indexOf(sec.key) !== -1; });
        if (!members.length) return;
        var secDiv = document.createElement('div');
        secDiv.style.cssText = 'width:100%; margin-top:6px;';
        secDiv.innerHTML = '<div style="font-size:0.65rem; color:#8b949e; letter-spacing:2px; margin-bottom:4px;">' + sec.label + '</div>';
        var tagsDiv = document.createElement('div');
        tagsDiv.style.cssText = 'display:flex; flex-wrap:wrap; gap:4px;';
        members.forEach(function(r) {
            var tag = document.createElement('div');
            tag.style.cssText = 'display:inline-flex; align-items:center; gap:4px; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15); border-radius:20px; padding:3px 10px; font-size:0.78rem; color:white;';
            var safeName = r.name.replace(/'/g, '&#39;');
            var extra = '';
            if (isRFC) {
                if (r.basin) extra += '<span style="color:#6cb4e4; font-size:0.68rem; margin-left:2px;">' + r.basin + '</span>';
                if (r.fim)   extra += '<span style="color:#f0a000; font-size:0.65rem; margin-left:3px;" title="FIM Assigned">★FIM</span>';
            } else {
                extra = '<span style="color:#8b949e; font-size:0.68rem; margin-left:2px;">(' + r.roles.join(', ') + ')</span>';
            }
            tag.innerHTML = '<span>' + r.name + '</span>' + extra +
                '<button onclick="removeRosterMember(&#39;' + safeName + '&#39;)" style="background:none;border:none;color:#cc3300;cursor:pointer;font-size:0.8rem;padding:0 0 0 3px;" title="Remove">&#10005;</button>';
            tagsDiv.appendChild(tag);
        });
        secDiv.appendChild(tagsDiv);
        el.appendChild(secDiv);
    });
}
// ── END ROSTER ─────────────────────────────────────────────────────────────────

function updateStaffingDropdowns() {
    var roster = getRoster();
    var opts = '<option value="">-- none --</option>' + roster.map(function(r){
        return '<option value="' + r.name + '">' + r.name + ' (' + r.roles.join(', ') + ')</option>';
    }).join('');

    // Update FIM, IC dropdowns
    ['nwc-fim-name','nwc-ic-name'].forEach(function(id){
        var el = document.getElementById(id);
        if (el) { var cur=el.value; el.innerHTML=opts; el.value=cur; }
    });

    // Update shift lead and forecaster-add dropdowns
    var shifts = getShifts();
    shifts.forEach(function(_, i){
        ['nwc-shift-lead-'+i, 'nwc-shift-fore-add-'+i].forEach(function(id){
            var el = document.getElementById(id);
            if (el) { var cur=el.value; el.innerHTML=opts; el.value=cur; }
        });
    });
}

function addShift() {
    var shifts = getShifts();
    shifts.push({ start: "", end: "", lead: "", forecaster: "" });
    saveShifts(shifts);
    renderShifts();
}

function removeShift(i) {
    var shifts = getShifts();
    if (shifts.length <= 1) return;
    shifts.splice(i, 1);
    saveShifts(shifts);
    renderShifts();
}

function renderShifts() {
    var shifts = getShifts();
    var roster = getRoster();
    var isNWC  = (customFrameConfig.profile === 'NWC');
    var isRFC  = currentOfficeType() === 'rfc';
    var isWFO  = currentOfficeType() === 'wfo';
    var showBasinFIM = isRFC || isWFO;
    var shiftTypes = isNWC ? [] : getCustomShiftTypes();
    var typeOpts = '<option value="">-- type --</option>' + shiftTypes.map(function(t){
        return '<option value="'+t+'">'+t+'</option>';
    }).join('');
    var leadRole = isRFC ? 'Lead Hydro' : (isWFO ? 'Shift Lead' : 'Lead');
    var foreRole = isRFC ? 'Hydro/HAS'  : (isWFO ? 'Forecaster' : 'Staff');
    var opts = '<option value="">-- none --</option>' + roster.map(function(r){ return '<option value="'+r.name+'">'+r.name+'</option>'; }).join('');
    var el = document.getElementById('nwc-shifts-list');
    if (!el) return;
    el.innerHTML = '';
    shifts.forEach(function(s, i) {
        var row = document.createElement('div');
        row.style.cssText = 'display:flex;flex-direction:column;gap:4px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:6px;padding:8px;';
        var shiftTypeRow = '';
        if (!isNWC) {
            var stInput = shiftTypes.length
                ? '<select id="nwc-shift-type-'+i+'" class="profile-select" style="flex:1;min-width:120px;" onchange="saveShiftField('+i+',\'shiftType\',this.value)">' + typeOpts + '</select>'
                : '<input type="text" id="nwc-shift-type-'+i+'" value="'+(s.shiftType||'')+'" placeholder="Shift name" class="station-txt-input" style="flex:1;text-align:left;" oninput="saveShiftField('+i+',\'shiftType\',this.value)">';
            shiftTypeRow = '<div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;margin-bottom:2px;"><span style="font-size:0.75rem;color:#8b949e;min-width:50px;">Type:</span>'+stInput+'</div>';
        }
        // Basin/FIM extension for lead (RFC/WFO)
        var leadBasinFIM = '';
        if (showBasinFIM) {
            leadBasinFIM =
                '<input type="text" id="sl-basin-'+i+'" value="'+(s.leadBasin||'')+'" placeholder="Basin" class="station-txt-input" style="width:80px;text-align:left;font-size:0.72rem;" oninput="saveShiftPersonField('+i+',\'lead\',\'leadBasin\',this.value)">' +
                '<label style="display:flex;align-items:center;gap:3px;cursor:pointer;font-size:0.72rem;color:#ccc;white-space:nowrap;">' +
                '<input type="checkbox" id="sl-fim-'+i+'" '+(s.leadFIM?'checked':'')+' onchange="saveShiftPersonField('+i+',\'lead\',\'leadFIM\',this.checked)"> FIM</label>';
        }
        row.innerHTML = shiftTypeRow +
            '<div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">' +
                '<span style="font-size:0.75rem;color:#8b949e;min-width:50px;">Shift '+(i+1)+'</span>' +
                '<input type="text" id="nwc-shift-start-'+i+'" value="'+(s.start||'')+'" placeholder="Start" class="station-txt-input" style="width:90px;text-align:center;" onfocus="openClockPicker(this)" oninput="saveShiftField('+i+',&quot;start&quot;,this.value)" onchange="saveShiftField('+i+',&quot;start&quot;,this.value)">' +
                '<span style="color:#ccc;font-size:0.8rem;">to</span>' +
                '<input type="text" id="nwc-shift-end-'+i+'" value="'+(s.end||'')+'" placeholder="End" class="station-txt-input" style="width:90px;text-align:center;" onfocus="openClockPicker(this)" oninput="saveShiftField('+i+',&quot;end&quot;,this.value)" onchange="saveShiftField('+i+',&quot;end&quot;,this.value)">' +
                (i >= 2 ? '<button onclick="removeShift('+i+')" style="background:none;border:none;color:#cc3300;cursor:pointer;font-size:0.9rem;margin-left:auto;">✕</button>' : '') +
            '</div>' +
            '<div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">' +
                '<span style="font-size:0.72rem;color:#8b949e;min-width:50px;">'+leadRole+':</span>' +
                '<select id="nwc-shift-lead-'+i+'" class="profile-select" style="flex:1;min-width:100px;" onchange="saveShiftField('+i+',\"lead\",this.value)">' + opts + '</select>' +
                leadBasinFIM +
            '</div>' +
            '<div id="nwc-shift-fore-container-'+i+'" style="display:flex;flex-direction:column;gap:4px;">' +
                '<div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">' +
                    '<span style="font-size:0.72rem;color:#8b949e;min-width:50px;">'+foreRole+':</span>' +
                    '<div id="nwc-shift-fore-list-'+i+'" style="display:flex;flex-wrap:wrap;gap:4px;flex:1;"></div>' +
                    '<select id="nwc-shift-fore-add-'+i+'" class="profile-select" style="min-width:100px;">' + opts + '</select>' +
                    '<button onclick="addForecaster('+i+')" style="background:#1a6e2e;border:1px solid #2ea84a;color:white;padding:3px 10px;border-radius:4px;cursor:pointer;font-size:0.8rem;white-space:nowrap;">+ Add</button>' +
                '</div>' +
            '</div>';
        el.appendChild(row);
        document.getElementById('nwc-shift-lead-'+i).value = s.lead || '';
        var typeEl = document.getElementById('nwc-shift-type-'+i);
        if (typeEl && s.shiftType) typeEl.value = s.shiftType;
        renderForecasters(i, s.forecasters || (s.forecaster ? [s.forecaster] : []), s.foreData || {}, showBasinFIM);
    });
}

function saveShiftPersonField(shiftIdx, personType, field, value) {
    var shifts = getShifts();
    if (!shifts[shiftIdx]) return;
    shifts[shiftIdx][field] = value;
    saveShifts(shifts);
    scheduleHydroDispatch();
}

function saveShiftField(i, field, value) {
    var shifts = getShifts();
    if (shifts[i]) { shifts[i][field] = value; saveShifts(shifts); scheduleHydroDispatch(); }
}

function addForecaster(i) {
    var sel = document.getElementById('nwc-shift-fore-add-' + i);
    if (!sel || !sel.value) return;
    var shifts = getShifts();
    if (!shifts[i]) return;
    if (!shifts[i].forecasters) shifts[i].forecasters = [];
    if (shifts[i].forecasters.indexOf(sel.value) === -1) {
        shifts[i].forecasters.push(sel.value);
        // Pre-populate basin/FIM from roster defaults
        var rosterEntry = getRoster().find(function(r){ return r.name === sel.value; });
        if (rosterEntry) {
            if (!shifts[i].foreData) shifts[i].foreData = {};
            shifts[i].foreData[sel.value] = { basin: rosterEntry.basin || '', fim: !!rosterEntry.fim };
        }
        saveShifts(shifts);
        var showBF = currentOfficeType()==='rfc'||currentOfficeType()==='wfo';
        renderForecasters(i, shifts[i].forecasters, shifts[i].foreData||{}, showBF);
        scheduleHydroDispatch();
    }
}

function removeForecaster(i, name) {
    var shifts = getShifts();
    if (!shifts[i]) return;
    shifts[i].forecasters = (shifts[i].forecasters || []).filter(function(f){ return f !== name; });
    saveShifts(shifts);
    var showBF = currentOfficeType()==='rfc'||currentOfficeType()==='wfo';
    renderForecasters(i, shifts[i].forecasters, shifts[i].foreData||{}, showBF);
    scheduleHydroDispatch();
}

// ── RFC BASIN LIST ────────────────────────────────────────────────────────────
function getBasinList() {
    try { return JSON.parse(localStorage.getItem(_lsPrefix() + '_BASINS') || '[]'); } catch(e) { return []; }
}
function saveBasinList(basins) {
    try { localStorage.setItem(_lsPrefix() + '_BASINS', JSON.stringify(basins)); } catch(e) {}
}
function addBasinToList() {
    var input = document.getElementById('new-basin-input');
    var name = (input.value || '').trim();
    if (!name) return;
    var basins = getBasinList();
    if (basins.indexOf(name) === -1) { basins.push(name); saveBasinList(basins); }
    input.value = '';
    renderBasinListTags();
    renderShifts();
    scheduleHydroDispatch();
}
function removeBasinFromList(name) {
    saveBasinList(getBasinList().filter(function(b){ return b !== name; }));
    renderBasinListTags();
    renderShifts();
}
function renderBasinListTags() {
    var el = document.getElementById('basin-list-tags');
    if (!el) return;
    el.innerHTML = '';
    getBasinList().forEach(function(b) {
        var tag = document.createElement('div');
        tag.style.cssText = 'display:inline-flex;align-items:center;gap:4px;background:rgba(30,126,173,0.15);border:1px solid rgba(30,126,173,0.35);border-radius:4px;padding:2px 8px;font-size:0.75rem;color:#58c4f5;';
        var safe = b.replace(/'/g,"&#39;");
        tag.innerHTML = '<span>'+b+'</span><button onclick="removeBasinFromList(\''+safe+'\')" style="background:none;border:none;color:#cc3300;cursor:pointer;font-size:0.75rem;padding:0 0 0 3px;">✕</button>';
        el.appendChild(tag);
    });
}
// ── END RFC BASIN LIST ────────────────────────────────────────────────────────

function renderForecasters(i, forecasters, foreData, showBasinFIM) {
    var el = document.getElementById('nwc-shift-fore-list-' + i);
    if (!el) return;
    el.innerHTML = '';
    var basinList = showBasinFIM ? getBasinList() : [];
    (forecasters || []).forEach(function(name) {
        var data = (foreData && foreData[name]) || {};
        var assignedBasins = Array.isArray(data.basins) ? data.basins : (data.basin ? [data.basin] : []);
        var safeName = name.replace(/'/g, "&#39;");
        var tag = document.createElement('div');
        tag.style.cssText = 'display:flex;flex-direction:column;gap:4px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);border-radius:6px;padding:5px 8px;';

        var topRow = '<div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">' +
            '<span style="font-size:0.78rem;color:#fff;font-weight:700;">'+name+'</span>' +
            (showBasinFIM ? '<label style="display:flex;align-items:center;gap:2px;cursor:pointer;font-size:0.72rem;color:#ccc;white-space:nowrap;">' +
            '<input type="checkbox" '+(data.fim?'checked':'')+' onchange="saveForeDataFIM('+i+',\''+safeName+'\',this.checked)"> FIM</label>' : '') +
            '<button onclick="removeForecaster('+i+',\''+safeName+'\')" style="background:none;border:none;color:#cc3300;cursor:pointer;font-size:0.8rem;margin-left:auto;">✕</button>' +
            '</div>';

        var basinRow = '';
        if (showBasinFIM) {
            var basinTags = assignedBasins.map(function(b) {
                var sb = b.replace(/'/g,"&#39;");
                return '<span style="display:inline-flex;align-items:center;gap:2px;background:rgba(30,126,173,0.2);border:1px solid rgba(30,126,173,0.4);border-radius:3px;padding:1px 6px;font-size:0.7rem;color:#58c4f5;">' +
                    b + '<button onclick="removeForecasterBasin('+i+',\''+safeName+'\',\''+sb+'\')" style="background:none;border:none;color:#cc3300;cursor:pointer;font-size:0.65rem;padding:0 0 0 2px;line-height:1;">✕</button></span>';
            }).join('');

            var addId = 'fore-basin-' + i + '-' + safeName;
            var addCtrl = basinList.length
                ? '<select id="'+addId+'" class="profile-select" style="font-size:0.72rem;padding:2px 4px;flex:1;min-width:80px;"><option value="">+ Basin</option>' +
                  basinList.map(function(b){ return '<option value="'+b+'">'+b+'</option>'; }).join('') + '</select>' +
                  '<button onclick="addForecasterBasinFromSel('+i+',\''+safeName+'\',\''+addId+'\')" style="background:#1a4060;border:1px solid #1e6ea8;color:white;padding:2px 8px;border-radius:3px;cursor:pointer;font-size:0.7rem;white-space:nowrap;">+ Basin</button>'
                : '<input type="text" id="'+addId+'" placeholder="Basin name" class="station-txt-input" style="flex:1;font-size:0.72rem;padding:2px 4px;text-align:left;" onkeydown="if(event.key===\'Enter\'){addForecasterBasinFromTxt('+i+',\''+safeName+'\',\''+addId+'\')}">' +
                  '<button onclick="addForecasterBasinFromTxt('+i+',\''+safeName+'\',\''+addId+'\')" style="background:#1a4060;border:1px solid #1e6ea8;color:white;padding:2px 8px;border-radius:3px;cursor:pointer;font-size:0.7rem;white-space:nowrap;">+ Basin</button>';

            basinRow = '<div style="display:flex;align-items:center;gap:4px;flex-wrap:wrap;">' + basinTags + addCtrl + '</div>';
        }

        tag.innerHTML = topRow + basinRow;
        el.appendChild(tag);
    });
}

function saveForeDataFIM(shiftIdx, name, checked) {
    var shifts = getShifts();
    if (!shifts[shiftIdx]) return;
    if (!shifts[shiftIdx].foreData) shifts[shiftIdx].foreData = {};
    if (!shifts[shiftIdx].foreData[name]) shifts[shiftIdx].foreData[name] = {};
    shifts[shiftIdx].foreData[name].fim = checked;
    saveShifts(shifts);
    scheduleHydroDispatch();
}

function addForecasterBasinFromSel(shiftIdx, name, selId) {
    var sel = document.getElementById(selId);
    if (!sel || !sel.value) return;
    addForecasterBasin(shiftIdx, name, sel.value);
    sel.value = '';
}
function addForecasterBasinFromTxt(shiftIdx, name, inputId) {
    var inp = document.getElementById(inputId);
    if (!inp || !inp.value.trim()) return;
    addForecasterBasin(shiftIdx, name, inp.value.trim());
    inp.value = '';
}
function addForecasterBasin(shiftIdx, name, basin) {
    var shifts = getShifts();
    if (!shifts[shiftIdx]) return;
    if (!shifts[shiftIdx].foreData) shifts[shiftIdx].foreData = {};
    if (!shifts[shiftIdx].foreData[name]) shifts[shiftIdx].foreData[name] = {};
    var d = shifts[shiftIdx].foreData[name];
    if (!Array.isArray(d.basins)) d.basins = d.basin ? [d.basin] : [];
    if (d.basins.indexOf(basin) === -1) d.basins.push(basin);
    delete d.basin;
    saveShifts(shifts);
    var showBF = currentOfficeType()==='rfc'||currentOfficeType()==='wfo';
    renderForecasters(shiftIdx, shifts[shiftIdx].forecasters, shifts[shiftIdx].foreData||{}, showBF);
    scheduleHydroDispatch();
}
function removeForecasterBasin(shiftIdx, name, basin) {
    var shifts = getShifts();
    if (!shifts[shiftIdx]||!shifts[shiftIdx].foreData||!shifts[shiftIdx].foreData[name]) return;
    var d = shifts[shiftIdx].foreData[name];
    if (!Array.isArray(d.basins)) d.basins = d.basin ? [d.basin] : [];
    d.basins = d.basins.filter(function(b){ return b !== basin; });
    delete d.basin;
    saveShifts(shifts);
    var showBF = currentOfficeType()==='rfc'||currentOfficeType()==='wfo';
    renderForecasters(shiftIdx, shifts[shiftIdx].forecasters, shifts[shiftIdx].foreData||{}, showBF);
    scheduleHydroDispatch();
}
function initStaffingUI() {
    syncRosterAddUI();
    syncNonNWCSections();
    renderRoster();
    renderShifts();
    renderTomorrowShifts();
    updateStaffingDropdowns();
    initUpcomingDayTabs();
    initForecastTabs();

    // Show/hide FIM and IC based on level
    var level = customFrameConfig.nwcOpsLevel || 'Level 4';
    var fimEl = document.getElementById('nwc-fim-container');
    var icEl  = document.getElementById('nwc-ic-container');
    if (fimEl) fimEl.style.display = (level !== 'Level 4') ? 'flex' : 'none';
    if (icEl)  icEl.style.display  = (level === 'Level 1' || level === 'Level 2') ? 'flex' : 'none';

    // Load saved FIM/IC
    var fimic = getFIMIC();
    if (fimic.fimName)  { var el=document.getElementById('nwc-fim-name');  if(el) el.value=fimic.fimName; }
    if (fimic.fimStart) { var el=document.getElementById('nwc-fim-start'); if(el) el.value=fimic.fimStart; }
    if (fimic.fimEnd)   { var el=document.getElementById('nwc-fim-end');   if(el) el.value=fimic.fimEnd; }
    if (fimic.icName)   { var el=document.getElementById('nwc-ic-name');   if(el) el.value=fimic.icName; }
    if (fimic.icStart)  { var el=document.getElementById('nwc-ic-start');  if(el) el.value=fimic.icStart; }
    if (fimic.icEnd)    { var el=document.getElementById('nwc-ic-end');    if(el) el.value=fimic.icEnd; }
}

// ── STATUS MODE ───────────────────────────────────────────────────────────────
var _statusCurrentDay = 0;

function initStatusMode() {
    if (!window._STATUS_MODE) return;

    // Hide map, hero, footer — show status panel
    var mapWrapper = document.getElementById('map-wrapper');
    var hero       = document.getElementById('hero-container');
    var footer     = document.getElementById('footer-container');
    var panel      = document.getElementById('status-mode-panel');
    if (mapWrapper) mapWrapper.style.display = 'none';
    if (hero)       hero.style.display       = 'none';
    if (footer)     footer.style.display      = 'none';
    if (panel)      panel.style.display       = 'block';

    // Set day tab labels
    for (var d = 0; d < 4; d++) {
        var tab = document.getElementById('status-tab-' + d);
        if (tab) tab.innerText = getDayLabel(d);
    }

    renderStatusPanel();
}

function renderStatusPanel() {
    if (!window._STATUS_MODE) return;

    var oid  = customFrameConfig.officeId;
    var ocfg = OFFICE_CONFIGS[oid] || {};

    // Header
    var nameEl = document.getElementById('status-office-name');
    if (nameEl) nameEl.innerText = ocfg.name || oid;

    var opsEl = document.getElementById('status-ops-level-display');
    var reasonEl = document.getElementById('status-reason-display');
    var hoursEl = document.getElementById('status-hours-display');
    if (opsEl)    opsEl.innerText    = LEVEL_NAMES[customFrameConfig.nwcOpsLevel] || 'Level 4 (Normal Operations)';
    if (reasonEl && customFrameConfig.nwcOpsReason) {
        reasonEl.innerText  = '⚠ ' + customFrameConfig.nwcOpsReason;
        reasonEl.style.display = 'block';
    } else if (reasonEl) { reasonEl.style.display = 'none'; }
    if (hoursEl) hoursEl.innerText = 'Hours: ' + getHoursString();

    // Render all day panels — NWC/RFC show today+tomorrow only, WFO shows all 4
    var otype = currentOfficeType();
    var maxDays = (otype === 'wfo') ? 4 : 2;
    for (var d = 0; d < 4; d++) {
        var tab = document.getElementById('status-tab-' + d);
        var panel = document.getElementById('status-day-' + d);
        var show = d < maxDays;
        if (tab)   tab.style.display   = show ? '' : 'none';
        if (panel && !show) panel.style.display = 'none';
    }
    for (var d = 0; d < maxDays; d++) renderStatusDay(d);

    // Roster
    renderStatusRoster();

    // Backup — WFO only
    var bkpSection = document.getElementById('status-backup-section');
    if (bkpSection) bkpSection.style.display = (otype === 'wfo') ? 'flex' : 'none';
    if (otype === 'wfo') renderStatusBackup();

    // Forecast — WFO only
    var fcSection = document.getElementById('status-forecast-section');
    if (fcSection) fcSection.style.display = (otype === 'wfo') ? 'flex' : 'none';
    if (otype === 'wfo') renderStatusForecast();
}

function renderStatusForecast() {
    var payload = getForecastPayload();
    var hasForecast = payload.some(function(d){ return d.opsLevel || d.reason || d.qpf; });
    var section = document.getElementById('status-forecast-section');
    if (section) section.style.display = hasForecast ? 'flex' : 'none';
    var list = document.getElementById('status-forecast-list');
    if (!list) return;
    list.innerHTML = '';
    payload.forEach(function(d) {
        if (!d.opsLevel && !d.reason && !d.qpf) return;
        var row = document.createElement('div');
        row.style.cssText = 'background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:6px;padding:8px 12px;';
        var levelColor = d.opsLevel && d.opsLevel !== 'Level 4' ? '#f0a000' : '#2ea84a';
        row.innerHTML =
            '<div style="font-size:0.75rem;font-weight:700;color:#8b949e;margin-bottom:4px;">' + d.label + '</div>' +
            (d.opsLevel ? '<div style="font-size:0.82rem;color:'+levelColor+';font-weight:700;">' + (LEVEL_NAMES[d.opsLevel]||d.opsLevel) + '</div>' : '') +
            (d.reason   ? '<div style="font-size:0.8rem;color:#ccc;margin-top:2px;">' + d.reason + '</div>' : '') +
            (d.qpf      ? '<div style="font-size:0.78rem;color:#6cb4e4;margin-top:2px;">QPF: ' + d.qpf + '</div>' : '');
        list.appendChild(row);
    });
}

function renderStatusBackup() {
    var data = getBackupData();
    var hasUp = data.backingUp && data.backingUp.length;
    var hasBy = data.backedUpBy && data.backedUpBy.length;
    var section = document.getElementById('status-backup-section');
    if (section) section.style.display = (hasUp || hasBy) ? 'flex' : 'none';

    var upSection = document.getElementById('status-backing-up');
    var bySection = document.getElementById('status-backed-up-by');
    if (upSection) upSection.style.display = hasUp ? 'flex' : 'none';
    if (bySection) bySection.style.display = hasBy ? 'flex' : 'none';

    var upList = document.getElementById('status-backing-up-list');
    if (upList) {
        upList.innerHTML = '';
        (data.backingUp || []).forEach(function(e) {
            upList.innerHTML += '<div style="display:flex;align-items:center;gap:8px;padding:4px 0;">' +
                '<span style="font-weight:700;color:#6cb4e4;font-size:0.85rem;min-width:70px;">'+e.office+'</span>' +
                '<span style="color:#ccc;font-size:0.82rem;">'+(e.reason||'')+'</span></div>';
        });
    }
    var byList = document.getElementById('status-backed-up-by-list');
    if (byList) {
        byList.innerHTML = '';
        (data.backedUpBy || []).forEach(function(e) {
            byList.innerHTML += '<div style="display:flex;align-items:center;gap:8px;padding:4px 0;">' +
                '<span style="font-weight:700;color:#2ea84a;font-size:0.85rem;min-width:70px;">'+e.office+'</span>' +
                '<span style="color:#ccc;font-size:0.82rem;">'+(e.reason||'')+'</span></div>';
        });
    }
}

function renderStatusDay(dayIdx) {
    var container = document.getElementById('status-shifts-' + dayIdx);
    if (!container) return;
    container.innerHTML = '';

    var shifts  = getShiftsByDay(dayIdx);
    var roster  = getRoster();
    var isRFC   = currentOfficeType() === 'rfc';

    if (!shifts.length) {
        container.innerHTML = '<div style="color:#555; font-size:0.82rem; padding:8px;">No shifts scheduled.</div>';
        return;
    }

    shifts.forEach(function(s, i) {
        if (!s.lead && !(s.forecasters && s.forecasters.length)) return;
        var card = document.createElement('div');
        card.className = 'status-shift-card';

        var timeStr = (s.start && s.end) ? s.start + ' – ' + s.end : '';
        var typeName = s.shiftType ? '<span style="color:#58c4f5;font-weight:700;"> ' + s.shiftType + '</span>' : '';
        card.innerHTML = '<div class="status-shift-time">SHIFT ' + (i+1) + typeName + (timeStr ? '  <span style="color:#8b949e;">' + timeStr + '</span>' : '') + '</div>';

        // Lead
        if (s.lead) {
            var roleLabel = isRFC ? 'Lead Hydro' : 'Shift Lead';
            card.innerHTML += '<div class="status-person-row">' +
                '<span class="status-role-badge lead">' + roleLabel.toUpperCase() + '</span>' +
                '<span style="color:#fff;">' + s.lead + '</span>' +
                '</div>';
        }

        // Forecasters / hydros
        var people = s.forecasters || (s.forecaster ? [s.forecaster] : []);
        people.forEach(function(name) {
            var roleLabel = isRFC ? 'Hydro' : 'Forecaster';
            // Check if this person has a basin/FIM in roster
            var rosterEntry = roster.find(function(r){ return r.name === name; });
            var extra = '';
            if (rosterEntry && rosterEntry.basin) extra += ' <span style="color:#6cb4e4;font-size:0.72rem;">(' + rosterEntry.basin + ')</span>';
            if (rosterEntry && rosterEntry.fim)   extra += ' <span class="status-role-badge fim">FIM</span>';
            card.innerHTML += '<div class="status-person-row">' +
                '<span class="status-role-badge">' + roleLabel.toUpperCase() + '</span>' +
                '<span style="color:#ddd;">' + name + extra + '</span>' +
                '</div>';
        });

        container.appendChild(card);
    });

    // FIM Coordinator / IC (from FIMIC data, show on day 0 only)
    if (dayIdx === 0) {
        var fimic = getFIMIC();
        if (fimic.fimName) {
            var fimCard = document.createElement('div');
            fimCard.className = 'status-shift-card';
            fimCard.innerHTML = '<div class="status-shift-time">FIM / IC</div>' +
                (fimic.fimName ? '<div class="status-person-row"><span class="status-role-badge fim">FIM COORDINATOR</span><span style="color:#fff;">' + fimic.fimName + (fimic.fimStart ? ' <span style="color:#8b949e;font-size:0.72rem;">' + fimic.fimStart + '–' + fimic.fimEnd + '</span>' : '') + '</span></div>' : '') +
                (fimic.icName  ? '<div class="status-person-row"><span class="status-role-badge lead">IC</span><span style="color:#fff;">' + fimic.icName + '</span></div>' : '');
            container.appendChild(fimCard);
        }
    }
}

function renderStatusRoster() {
    var container = document.getElementById('status-roster-display');
    if (!container) return;
    container.innerHTML = '';
    var roster = getRoster();
    var isRFC  = currentOfficeType() === 'rfc';
    roster.forEach(function(r) {
        if (!r.roles) r.roles = [r.role || 'Forecaster'];
        var tag = document.createElement('div');
        tag.style.cssText = 'display:inline-flex; align-items:center; gap:5px; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12); border-radius:20px; padding:4px 12px; font-size:0.8rem; color:#fff;';
        var roleStr = r.roles.join(', ');
        var extra = '';
        if (isRFC && r.basin) extra += '<span style="color:#6cb4e4;font-size:0.7rem;margin-left:3px;">' + r.basin + '</span>';
        if (isRFC && r.fim)   extra += '<span style="color:#f0a000;font-size:0.68rem;margin-left:3px;">★FIM</span>';
        tag.innerHTML = '<span>' + r.name + '</span><span style="color:#8b949e;font-size:0.7rem;">(' + roleStr + ')</span>' + extra;
        container.appendChild(tag);
    });
}

function showStatusDay(dayIdx) {
    _statusCurrentDay = dayIdx;
    for (var d = 0; d < 4; d++) {
        var panel = document.getElementById('status-day-' + d);
        var tab   = document.getElementById('status-tab-' + d);
        if (panel) panel.style.display = (d === dayIdx) ? 'block' : 'none';
        if (tab)   tab.classList.toggle('active-tab', d === dayIdx);
    }
}

// After status update, refresh the panel display
function refreshStatusPanelIfActive() {
    if (window._STATUS_MODE) renderStatusPanel();
}
// ── END STATUS MODE ───────────────────────────────────────────────────────────

// ── JSON CORRUPTION HANDLING ──────────────────────────────────────────────────
function showJSONCorruptWarning(fileUrl) {
    var syncDot  = document.getElementById('sync-dot');
    var syncText = document.getElementById('sync-text');
    if (syncDot)  { syncDot.style.background  = '#cc3300'; syncDot.style.animation = 'none'; }
    if (syncText) { syncText.innerText = 'JSON ERROR'; syncText.style.color = '#cc3300'; }

    // Show recovery banner
    var existing = document.getElementById('json-corrupt-banner');
    if (existing) return;
    var banner = document.createElement('div');
    banner.id = 'json-corrupt-banner';
    banner.style.cssText = 'position:fixed;top:0;left:0;right:0;z-index:9998;background:#7a1a00;color:#fff;padding:8px 16px;font-size:0.82rem;display:flex;align-items:center;justify-content:space-between;gap:8px;';
    var fileName = (fileUrl || '').split('/').pop().split('?')[0];
    banner.innerHTML =
        '<span>⚠ <strong>' + fileName + '</strong> is corrupt or malformed — status data could not be loaded.</span>' +
        '<div style="display:flex;gap:8px;">' +
            '<button onclick="recoverStatusJSON()" style="background:#cc3300;border:1px solid #ff6644;color:#fff;padding:4px 12px;border-radius:4px;cursor:pointer;font-size:0.8rem;font-weight:700;">↺ Recover (Push Clean JSON)</button>' +
            '<button onclick="dismissCorruptBanner()" style="background:transparent;border:1px solid rgba(255,255,255,0.3);color:#fff;padding:4px 10px;border-radius:4px;cursor:pointer;font-size:0.8rem;">Dismiss</button>' +
        '</div>';
    document.body.insertBefore(banner, document.body.firstChild);
}

function dismissCorruptBanner() {
    var b = document.getElementById('json-corrupt-banner');
    if (b) b.remove();
}

function recoverStatusJSON() {
    // Requires auth token — push a clean skeleton for this office
    if (!isWpodAuthenticated || !customFrameConfig.dispatchToken) {
        alert('You must be authenticated to recover the status JSON.\nUnlock with your office password first, then try again.');
        return;
    }
    var oid = customFrameConfig.officeId;
    if (!confirm('Push a clean (empty) status record for ' + oid + ' to the server?\nThis overwrites only this office\'s data — other offices are preserved.')) return;

    // Build minimal clean payload
    var token = customFrameConfig.dispatchToken;
    fetch('https://api.github.com/repos/glen104/nwc-status-private/dispatches', {
        method: 'POST',
        headers: { 'Authorization': 'token ' + token, 'Accept': 'application/vnd.github.v3+json', 'Content-Type': 'application/json' },
        body: JSON.stringify({
            event_type: 'hydro_status_update',
            client_payload: {
                officeId: oid,
                opsLevel: 'Level 4 (Normal Operations)',
                reason: '', hours: 'See schedule',
                staffing: { shifts: [], fim: null, ic: null },
                tomorrow: [], day3: [], day4: [], roster: [],
                backup: { backingUp: [], backedUpBy: [] },
                shiftTypes: [], forecast: {}, preferences: {}
            }
        })
    })
    .then(function(r) {
        if (r.status === 204) {
            alert('Clean JSON dispatched. The file will update in ~30 seconds.\nRefresh the page after that.');
            dismissCorruptBanner();
        } else {
            alert('Dispatch failed: ' + r.status + '. Check your token and try again.');
        }
    })
    .catch(function(e) { alert('Recovery failed: ' + e.message); });
}
// ── END JSON CORRUPTION HANDLING ──────────────────────────────────────────────
function getCustomShiftTypes() {
    try { return JSON.parse(localStorage.getItem(_lsPrefix() + '_SHIFT_TYPES') || '[]'); } catch(e) { return []; }
}
function saveCustomShiftTypes(types) {
    try { localStorage.setItem(_lsPrefix() + '_SHIFT_TYPES', JSON.stringify(types)); } catch(e) {}
}

function addCustomShiftType() {
