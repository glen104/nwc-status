        sel.innerHTML = '<option value="none">— none —</option>';
        zoneOrder.forEach(function(zKey) {
            var opt = document.createElement('option');
            opt.value = zKey;
            opt.innerText = zoneNames[zKey] || zKey;
            sel.appendChild(opt);
        });
        // Pre-fill with current hero zones
        sel.value = activeHeroZones[i] || 'none';
    });

    // Populate visible zone checkboxes
    var container = document.getElementById('office-default-zones-checkboxes');
    if (container) {
        container.innerHTML = '';
        zoneOrder.forEach(function(zKey) {
            var label = document.createElement('label');
            label.style.cssText = 'display:flex; align-items:center; gap:4px; cursor:pointer; font-size:0.78rem; color:#ccc;';
            var cb = document.createElement('input');
            cb.type = 'checkbox';
            cb.value = zKey;
            cb.id = 'od-zone-' + zKey;
            cb.checked = visibleTimeZones.includes(zKey);
            label.appendChild(cb);
            label.appendChild(document.createTextNode(zoneNames[zKey] || zKey));
            container.appendChild(label);
        });
