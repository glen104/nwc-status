function renderHomeGPSPin() {
    if (homeMarker) {
        map.removeLayer(homeMarker);
    }
    if (customFrameConfig.homeGPS.lat !== null && customFrameConfig.homeGPS.lng !== null) {
        const homeIcon = L.divIcon({ 
            className: 'custom-icon', 
