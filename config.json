function addTomorrowForecaster(i) {
    var sel = document.getElementById('nwc-tmrw-fore-add-' + i);
    if (!sel || !sel.value) return;
    var shifts = getTomorrowShifts();
    if (!shifts[i]) return;
    if (!shifts[i].forecasters) shifts[i].forecasters = [];
    if (shifts[i].forecasters.indexOf(sel.value) === -1) {
        shifts[i].forecasters.push(sel.value);
        saveTomorrowShifts(shifts);
        renderTomorrowForecasters(i, shifts[i].forecasters);
    }
}

