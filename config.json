// ── SLACK POST GENERATOR ──────────────────────────────────────────────────────
var _slackTemplateSaveTimer = null;

function getSlackTemplate() {
    try { return localStorage.getItem(_lsPrefix() + '_SLACK_TEMPLATE') || ''; } catch(e) { return ''; }
}
function saveSlackTemplate(template) {
    try { localStorage.setItem(_lsPrefix() + '_SLACK_TEMPLATE', template); } catch(e) {}
}
function scheduleSlackTemplateSave() {
    var tmpl = (document.getElementById('slack-template') || {}).value || '';
    clearTimeout(_slackTemplateSaveTimer);
    _slackTemplateSaveTimer = setTimeout(function(){ saveSlackTemplate(tmpl); }, 1500);
}
function toggleSlackSection() {
    var body = document.getElementById('slack-section-body');
    var btn  = document.getElementById('slack-toggle-btn');
    if (!body) return;
    var open = body.style.display !== 'none';
    body.style.display = open ? 'none' : 'flex';
    if (btn) btn.innerText = open ? '▼ Show' : '▲ Hide';
    if (!open) {
        var ta = document.getElementById('slack-template');
        if (ta && !ta.value) ta.value = getSlackTemplate();
    }
}
function generateSlackPost() {
    var ta = document.getElementById('slack-template');
    if (!ta || !ta.value.trim()) { alert('Enter a template first.'); return; }
    var preview = document.getElementById('slack-preview');
    if (preview) { preview.innerText = renderSlackTemplate(ta.value); preview.style.display = 'block'; }
}
function renderSlackTemplate(template) {
    var shifts  = getShifts();
    var fimic   = getFIMIC();
    var roster  = getRoster();
    var ocfg    = OFFICE_CONFIGS[customFrameConfig.officeId] || {};
    var today   = new Date();
    var dateStr = today.toLocaleDateString('en-US', {weekday:'long', month:'long', day:'numeric', year:'numeric'});
    function st(i) { var s=shifts[i]; if(!s) return '--'; return (s.start&&s.end)?s.start+' – '+s.end:(s.start||s.end||'--'); }
    function sl(i) { return shifts[i]&&shifts[i].lead?shifts[i].lead:'--'; }
    function sf(i) { var s=shifts[i]; if(!s) return '--'; var f=s.forecasters||(s.forecaster?[s.forecaster]:[]); return f.length?f.join(', '):'--'; }
    var rosterStr = roster.map(function(r){ return r.name+' ('+(r.roles||[r.role||'Staff']).join('/')+')'; }).join(', ');
    return template
        .replace(/{office}/g,     ocfg.name||customFrameConfig.officeId||'Office')
        .replace(/{date}/g,       dateStr)
        .replace(/{opsLevel}/g,   LEVEL_NAMES[customFrameConfig.nwcOpsLevel]||customFrameConfig.nwcOpsLevel||'Level 4 (Normal Operations)')
        .replace(/{reason}/g,     customFrameConfig.nwcOpsReason||'N/A')
        .replace(/{hours}/g,      getHoursString())
        .replace(/{shift1}/g,     st(0)).replace(/{shift2}/g,st(1)).replace(/{shift3}/g,st(2))
        .replace(/{shift1Lead}/g, sl(0)).replace(/{shift2Lead}/g,sl(1)).replace(/{shift3Lead}/g,sl(2))
        .replace(/{shift1Fore}/g, sf(0)).replace(/{shift2Fore}/g,sf(1)).replace(/{shift3Fore}/g,sf(2))
        .replace(/{fim}/g,        fimic.fimName?(fimic.fimName+(fimic.fimStart?' ('+fimic.fimStart+'–'+fimic.fimEnd+')':'')):'None')
        .replace(/{ic}/g,         fimic.icName||'None')
        .replace(/{roster}/g,     rosterStr||'None');
}
function copySlackPost() {
    var ta = document.getElementById('slack-template');
    if (!ta||!ta.value.trim()) { generateSlackPost(); return; }
    var text = renderSlackTemplate(ta.value);
    var preview = document.getElementById('slack-preview');
    if (preview) { preview.innerText = text; preview.style.display = 'block'; }
    navigator.clipboard.writeText(text).then(function(){
        var btn = document.getElementById('slack-copy-btn');
        if (btn) { var orig=btn.innerText; btn.innerText='✓ Copied!'; setTimeout(function(){ btn.innerText=orig; },2000); }
    }).catch(function(){
        var t=document.createElement('textarea'); t.value=text;
        document.body.appendChild(t); t.select(); document.execCommand('copy'); document.body.removeChild(t);
    });
}
function initSlackTemplate() {
    var ta = document.getElementById('slack-template');
    if (ta) { var s=getSlackTemplate(); if (s) ta.value=s; }
}
// ── END SLACK POST ────────────────────────────────────────────────────────────

function getBackupData() {
    try { return JSON.parse(localStorage.getItem(_lsPrefix() + '_BACKUP') || '{"backingUp":[],"backedUpBy":[]}'); }
    catch(e) { return {backingUp:[], backedUpBy:[]}; }
}
function saveBackupData(data) {
    try { localStorage.setItem(_lsPrefix() + '_BACKUP', JSON.stringify(data)); } catch(e) {}
}

function addBackupEntry(direction) {
    var officeEl = document.getElementById(direction === 'up' ? 'backing-up-office' : 'backed-up-by-office');
    var reasonEl = document.getElementById(direction === 'up' ? 'backing-up-reason' : 'backed-up-by-reason');
    var office = (officeEl.value || '').trim().toUpperCase();
    var reason = (reasonEl.value || '').trim();
    if (!office) return;
    var data = getBackupData();
    var key  = direction === 'up' ? 'backingUp' : 'backedUpBy';
    // Avoid duplicates
    if (!data[key].some(function(e){ return e.office === office; })) {
        data[key].push({ office: office, reason: reason });
        saveBackupData(data);
    }
    officeEl.value = '';
    reasonEl.value = '';
    renderBackupLists();
    scheduleHydroDispatch();
}

function removeBackupEntry(direction, office) {
    var data = getBackupData();
    var key  = direction === 'up' ? 'backingUp' : 'backedUpBy';
    data[key] = data[key].filter(function(e){ return e.office !== office; });
    saveBackupData(data);
    renderBackupLists();
    scheduleHydroDispatch();
}

function renderBackupLists() {
    var data = getBackupData();
    ['backingUp', 'backedUpBy'].forEach(function(key) {
        var elId = key === 'backingUp' ? 'backing-up-list' : 'backed-up-by-list';
        var dir  = key === 'backingUp' ? 'up' : 'by';
        var color = key === 'backingUp' ? '#6cb4e4' : '#2ea84a';
        var el   = document.getElementById(elId);
        if (!el) return;
        el.innerHTML = '';
        (data[key] || []).forEach(function(entry) {
            var row = document.createElement('div');
            row.style.cssText = 'display:flex;align-items:center;gap:6px;padding:4px 8px;background:rgba(255,255,255,0.04);border-radius:4px;';
            var safeOffice = entry.office.replace(/'/g,"&#39;");
            row.innerHTML = '<span style="font-weight:700;color:'+color+';font-size:0.8rem;min-width:60px;">'+entry.office+'</span>' +
                '<span style="color:#ccc;font-size:0.8rem;flex:1;">'+(entry.reason||'')+'</span>' +
                '<button onclick="removeBackupEntry(\''+dir+'\',\''+safeOffice+'\')" style="background:none;border:none;color:#cc3300;cursor:pointer;font-size:0.8rem;">✕</button>';
            el.appendChild(row);
        });
    });
}
// ── END BACKUP RELATIONSHIPS ──────────────────────────────────────────────────

