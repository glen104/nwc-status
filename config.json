    if (hoursEl) {
        // Use server-loaded preference if available, else config default
        hoursEl.value = customFrameConfig.serverDefaultHours || (ocfg ? ocfg.defaultHours : '');
    }
}

function saveOfficeDefaults() {
    var statusEl = document.getElementById('office-defaults-status');
    var token = customFrameConfig.dispatchToken;
    if (!token) { statusEl.innerText = '✗ No dispatch token — config.json not set up yet.'; return; }

    var hours = (document.getElementById('office-default-hours').value || '').trim();
    var hero1 = document.getElementById('office-default-hero-1').value;
    var hero2 = document.getElementById('office-default-hero-2').value;
    var hero3 = document.getElementById('office-default-hero-3').value;
    var heroZones = [hero1, hero2, hero3].filter(function(z){ return z && z !== 'none'; });

    var visZones = [];
    zoneOrder.forEach(function(zKey) {
        var cb = document.getElementById('od-zone-' + zKey);
        if (cb && cb.checked) visZones.push(zKey);
    });

    var oid = customFrameConfig.officeId;
    statusEl.style.color = '#8b949e';
    statusEl.innerText = 'Saving...';

    fetch('https://api.github.com/repos/glen104/nwc-status-private/dispatches', {
        method: 'POST',
        headers: { 'Authorization': 'token ' + token, 'Accept': 'application/vnd.github.v3+json', 'Content-Type': 'application/json' },
        body: JSON.stringify({
            event_type: 'hydro_status_update',
            client_payload: {
                officeId: oid,
                opsLevel: LEVEL_NAMES[customFrameConfig.nwcOpsLevel] || 'Level 4 (Normal Operations)',
                reason: customFrameConfig.nwcOpsReason || '',
                hours: getHoursString(),
                staffing: getStaffingPayload(),
                tomorrow: getTomorrowStaffingPayload(),
                roster: getRoster(),
                preferences: { defaultHours: hours, heroZones: heroZones, visibleZones: visZones, displayName: customFrameConfig.nodeIdentifier || '' }
            }
        })
    })
    .then(function(r) {
        if (r.status === 204) {
            statusEl.style.color = '#2ea84a';
            statusEl.innerText = '✓ Office defaults saved — takes ~30s to apply.';
            applyOfficePreferences({ defaultHours: hours, heroZones: heroZones, visibleZones: visZones });
        } else {
            r.text().then(function(body){ console.log('Dispatch failed:', r.status, body); });
            statusEl.innerText = '✗ Dispatch failed: ' + r.status;
        }
    })
    .catch(function(e){ statusEl.innerText = '✗ Error: ' + e.message; });
}

function applyOfficePreferences(prefs) {
    if (!prefs) return;
    if (prefs.displayName) {
        customFrameConfig.nodeIdentifier = prefs.displayName;
        var stEl = document.getElementById('station-identifier');
        if (stEl) stEl.value = prefs.displayName;
        if (typeof handleIdentifierInput === 'function') customFrameConfig.nodeIdentifier = prefs.displayName;
    }
    if (prefs.defaultHours) {
        customFrameConfig.serverDefaultHours = prefs.defaultHours;
        var ocfg = OFFICE_CONFIGS[customFrameConfig.officeId];
        if (ocfg) ocfg.defaultHours = prefs.defaultHours;
        var defLabel = document.getElementById('hours-default-label');
        if (defLabel) defLabel.innerText = 'Use Default (' + prefs.defaultHours + ')';
    }
    if (prefs.heroZones && prefs.heroZones.length) {
        activeHeroZones = prefs.heroZones;
        ['hero-1','hero-2','hero-3'].forEach(function(id, i){
            var sel = document.getElementById(id);
            if (sel && prefs.heroZones[i]) sel.value = prefs.heroZones[i];
        });
        if (typeof renderHero === 'function') renderHero();
    }
    if (prefs.visibleZones && prefs.visibleZones.length) {
        visibleTimeZones = prefs.visibleZones;
        if (typeof rebuildUIContainers === 'function') rebuildUIContainers();
        if (typeof initSelectors === 'function') initSelectors();
    }
    if (prefs.slotColors && prefs.slotColors.length === 3) {
        customFrameConfig.slotColors = prefs.slotColors;
        prefs.slotColors.forEach(function(c, i) {
            document.documentElement.style.setProperty('--color-slot-' + (i+1), c);
            var el = document.getElementById('picker-slot-' + (i+1));
            if (el) el.value = c;
        });
    }
    if (prefs.use24Hour !== undefined) {
        use24Hour = prefs.use24Hour;
        var toggleEl = document.getElementById('modal-time-toggle');
        if (toggleEl) toggleEl.checked = use24Hour;
    }
    if (prefs.showSeconds !== undefined) {
        customFrameConfig.showSeconds = prefs.showSeconds;
        var secEl = document.getElementById('seconds-toggle');
        if (secEl) secEl.checked = prefs.showSeconds;
    }
    if (prefs.homeGPS && prefs.homeGPS.lat) {
        customFrameConfig.homeGPS = prefs.homeGPS;
        var latEl = document.getElementById('home-lat-input');
        var lngEl = document.getElementById('home-lng-input');
        if (latEl) latEl.value = prefs.homeGPS.lat;
        if (lngEl) lngEl.value = prefs.homeGPS.lng;
        if (typeof renderHomeGPSPin === 'function') renderHomeGPSPin();
    }
    if (prefs.homeTZ) {
        customFrameConfig.homeTZ = prefs.homeTZ;
        var tzEl = document.getElementById('home-tz-selector');
        if (tzEl) tzEl.value = prefs.homeTZ;
    }
    if (prefs.slackTemplate) {
        saveSlackTemplate(prefs.slackTemplate);
        var ta = document.getElementById('slack-template');
        if (ta && !ta.value) ta.value = prefs.slackTemplate;
    }
    if (prefs.markerPositions && Object.keys(prefs.markerPositions).length) {
        saveMarkerPositions('sd', prefs.markerPositions);
        // Apply to map if not in PC mode
        if (!isPCMode) {
            Object.keys(prefs.markerPositions).forEach(function(id) {
                var p = prefs.markerPositions[id];
                if (markers[id]) markers[id].setLatLng([p.lat, p.lng]);
            });
        }
        console.log('SD marker positions applied from server preferences');
    }
}
