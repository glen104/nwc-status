        if (!badge) return;
        badge.innerText = statusVal;
        badge.className = "status-value-badge"; 
        
        if (statusVal === "NORMAL") badge.classList.add("status-normal");
        else if (statusVal === "Enhanced Caution") badge.classList.add("status-caution");
        else if (statusVal === "Critical Weather Day") badge.classList.add("status-critical");
    });
}

