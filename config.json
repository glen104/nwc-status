function applyMapClockSize(val) {
    if (isNaN(val)) return;
    val = Math.max(0.4, Math.min(1.6, val));
    document.documentElement.style.setProperty('--map-clock-scale', val);
    var lbl = document.getElementById('map-clock-size-label');
    if (lbl) lbl.innerText = Math.round(val * 100) + '%';
    var slider = document.getElementById('map-clock-size-slider');
    if (slider && parseFloat(slider.value) !== val) slider.value = val;
    try { localStorage.setItem('MAP_CLOCK_SCALE', val); } catch(e) {}
}
function loadMapClockSize() {
    var saved = 1.0;  // default = original full size
    try { var s = localStorage.getItem('MAP_CLOCK_SCALE'); if (s) saved = parseFloat(s); } catch(e) {}
    applyMapClockSize(saved);
}
