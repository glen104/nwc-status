        homeMarker = L.marker([customFrameConfig.homeGPS.lat, customFrameConfig.homeGPS.lng], { icon: homeIcon }).addTo(map)
            .bindTooltip(`<div style='font-weight:900; color:#58a6ff;'>HOME STATION NODE${tzTagSuffix}</div>`, { permanent: false, direction: 'top' });
    }
}

// ── HYDRO CONFIG FETCH & DECRYPT ────────────────────────────────────────────
var encryptedDispatchToken = null;  // loaded from config.json (per-office)
var decryptedDispatchToken = null;  // decrypted in memory only on auth unlock

// Fetch config.json from public repo on page load — load per-office token
fetch((window._GITLAB_CDN || 'https://cdn.jsdelivr.net/gh/glen104/nwc-status@main/') + 'config.json?t=' + Math.floor(Date.now()/30000))
    .then(function(r) { return r.ok ? r.text() : null; })
    .then(function(text) {
        if (!text) return null;
        try { return JSON.parse(text); }
        catch(e) { console.warn('config.json is corrupt — tokens unavailable', e); return null; }
    })
    .then(function(d) {
        if (!d) return;
        var oid = customFrameConfig.officeId;  // e.g. 'WPOD', 'OHRFC', 'LUB'
        // New structure: d.offices[officeId].dispatchToken
        // Legacy fallback: d.dispatchToken (WPOD only)
        if (d.offices && d.offices[oid] && d.offices[oid].dispatchToken) {
            encryptedDispatchToken = d.offices[oid].dispatchToken;
            console.log('Config loaded for office:', oid);
        } else if (oid === 'NWCO' && d.dispatchToken) {
            encryptedDispatchToken = d.dispatchToken;
            window._legacyDispatchToken = d.dispatchToken;  // store as fallback for all offices
            console.log('Config loaded (legacy WPOD fallback)');
        } else if (d.dispatchToken) {
            // Always store legacy token as fallback regardless of current office
            window._legacyDispatchToken = d.dispatchToken;
            console.log('Legacy token stored as fallback for:', oid);
        } else {
            console.log('No dispatch token found for office:', oid);
        }
    })
    .catch(function(e) { console.log('Config fetch failed:', e); });

async function deriveKey(password, salt) {
    var enc = new TextEncoder();
    var keyMaterial = await crypto.subtle.importKey(
        'raw', enc.encode(password), 'PBKDF2', false, ['deriveKey']
    );
    return crypto.subtle.deriveKey(
        { name: 'PBKDF2', salt: salt, iterations: 100000, hash: 'SHA-256' },
        keyMaterial,
        { name: 'AES-CBC', length: 256 },
        false,
        ['decrypt']
    );
}

async function decryptToken(encryptedB64, password) {
    try {
        var combined = Uint8Array.from(atob(encryptedB64), function(c) { return c.charCodeAt(0); });
        var salt       = combined.slice(0, 16);
        var iv         = combined.slice(16, 32);
        var ciphertext = combined.slice(32);
        var key = await deriveKey(password, salt);
        var decrypted = await crypto.subtle.decrypt(
            { name: 'AES-CBC', iv: iv }, key, ciphertext
        );
        return new TextDecoder().decode(decrypted);
    } catch(e) {
        return null;
    }
}
// ── END HYDRO CONFIG ──────────────────────────────────────────────────────────

// Keep legacy name callable from HTML onclick
async function validateWpodAuth() { return validateOfficeAuth(); }

// ── PASSWORD STORAGE (plain text for testing — upgrade to crypto later) ────────
function getOfficePassword(officeId) {
    // Check localStorage for a custom password first
    try {
        var stored = localStorage.getItem('PWD_' + officeId);
        if (stored) return stored;
    } catch(e) {}
    // Fall back to default from OFFICE_CONFIGS
    var ocfg = OFFICE_CONFIGS[officeId];
    return ocfg ? ocfg.defaultPwd : officeId;
}
function setOfficePassword(officeId, newPwd) {
    try { localStorage.setItem('PWD_' + officeId, newPwd); } catch(e) {}
}

async function validateOfficeAuth() {
    const passInput = document.getElementById('wpod-password-input').value.trim();
    if (!passInput) { alert("Please enter the security code."); return; }

    var oid = customFrameConfig.officeId;
    var expected = getOfficePassword(oid);

    if (passInput !== expected) {
        alert("Authentication code discrepancy encountered.");
        return;
    }

    // Auth passed — try to get dispatch token
    if (encryptedDispatchToken) {
        // Try office-specific token with entered password
        var decoded = await decryptToken(encryptedDispatchToken, passInput);
        // Also try full office ID if short password used
        if (!decoded || !(decoded.startsWith('github_pat_') || decoded.startsWith('ghp_') || decoded.startsWith('ghs_'))) {
            decoded = await decryptToken(encryptedDispatchToken, oid);
        }
        if (decoded && (decoded.startsWith('github_pat_') || decoded.startsWith('ghp_') || decoded.startsWith('ghs_'))) {
            decryptedDispatchToken = decoded;
            customFrameConfig.dispatchToken = decoded;
            console.log('Dispatch token decrypted OK for:', oid);
        }
    }

    // Fallback: if no office-specific token, try the legacy WPOD token from config.json
    // All offices use the same underlying PAT — this covers testing before --batch is run
    if (!customFrameConfig.dispatchToken && window._legacyDispatchToken) {
        var decoded2 = await decryptToken(window._legacyDispatchToken, 'NWCO');
        if (decoded2 && (decoded2.startsWith('github_pat_') || decoded2.startsWith('ghp_') || decoded2.startsWith('ghs_'))) {
            decryptedDispatchToken = decoded2;
            customFrameConfig.dispatchToken = decoded2;
            console.log('Dispatch token OK via legacy WPOD fallback for:', oid);
        }
    }    // ── AUTH SUCCESS ─────────────────────────────────────────────────────────
    isWpodAuthenticated = true;
    // Store password in memory for password-change operations
    window._currentOfficePassword = passInput;

    document.getElementById('wpod-auth-gate').style.display = "none";
    document.getElementById('nwc-secure-controls').style.display = "flex";

    // Show change-password section for any URL-locked office (always accessible)
    var cpEl = document.getElementById('office-change-password-section');
    if (cpEl) cpEl.style.display = window._URL_OFFICE_ID ? 'flex' : 'none';

    // Sync show/hide state based on saved config
    var _level = customFrameConfig.nwcOpsLevel || 'Level 4';
    document.getElementById('nwc-ops-level-selector').value = _level;
    var _rc  = document.getElementById('nwc-reason-input-container');
    var _hc  = document.getElementById('nwc-hours-container');
    var _uc  = document.getElementById('nwc-update-btn-container');
    var _sc  = document.getElementById('nwc-staffing-container');
    var _fim = document.getElementById('nwc-fim-container');
    var _ic  = document.getElementById('nwc-ic-container');
    if (_level !== 'Level 4') {
        if (_rc)  _rc.style.display  = 'flex';
        if (_hc)  _hc.style.display  = 'flex';
        if (_uc)  _uc.style.display  = 'flex';
        if (_sc)  _sc.style.display  = 'flex';
        if (_fim) _fim.style.display = 'flex';
        if (_ic)  _ic.style.display  = (_level === 'Level 1' || _level === 'Level 2') ? 'flex' : 'none';
    } else {
        if (_rc)  _rc.style.display  = 'none';
        if (_hc)  _hc.style.display  = 'none';
        if (_uc)  _uc.style.display  = 'none';
        if (_sc)  _sc.style.display  = 'none';
        if (_fim) _fim.style.display = 'none';
        if (_ic)  _ic.style.display  = 'none';
    }
    initStaffingUI();
    handleHoursChange();
    applyOfficeLabels();
    populateOfficeDefaultsUI();
    initSlackTemplate();
}

