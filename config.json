function getTomorrowShifts() {
    try { return JSON.parse(localStorage.getItem(_lsPrefix() + '_TOMORROW_SHIFTS') || '[]'); } catch(e) { return []; }
}
function saveTomorrowShifts(shifts) {
    try { localStorage.setItem(_lsPrefix() + '_TOMORROW_SHIFTS', JSON.stringify(shifts)); } catch(e) {}
}
function getDay3Shifts() {
    try { return JSON.parse(localStorage.getItem(_lsPrefix() + '_DAY3_SHIFTS') || '[]'); } catch(e) { return []; }
}
function saveDay3Shifts(shifts) {
    try { localStorage.setItem(_lsPrefix() + '_DAY3_SHIFTS', JSON.stringify(shifts)); } catch(e) {}
}
function getDay4Shifts() {
    try { return JSON.parse(localStorage.getItem(_lsPrefix() + '_DAY4_SHIFTS') || '[]'); } catch(e) { return []; }
}
function saveDay4Shifts(shifts) {
    try { localStorage.setItem(_lsPrefix() + '_DAY4_SHIFTS', JSON.stringify(shifts)); } catch(e) {}
}

// Get shifts by day index (0=today, 1=tomorrow, 2=day3, 3=day4)
function getShiftsByDay(dayIdx) {
    if (dayIdx === 0) return getShifts();
    if (dayIdx === 1) return getTomorrowShifts();
    if (dayIdx === 2) return getDay3Shifts();
    if (dayIdx === 3) return getDay4Shifts();
    return [];
}
function saveShiftsByDay(dayIdx, shifts) {
    if (dayIdx === 0) saveShifts(shifts);
    else if (dayIdx === 1) saveTomorrowShifts(shifts);
    else if (dayIdx === 2) saveDay3Shifts(shifts);
    else if (dayIdx === 3) saveDay4Shifts(shifts);
}

// Get human-readable label for a day offset from today
function getDayLabel(offset) {
    if (offset === 0) return 'TODAY';
    if (offset === 1) return 'TOMORROW';
    var d = new Date();
    d.setDate(d.getDate() + offset);
    return d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' }).toUpperCase();
}

function addTomorrowShift() {
