<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OWP Time Zone - OPERATIONAL</title>
    <!-- BUILD: 2026-05-25 14:31 UTC -->

    <link id="dynamic-favicon" rel="icon" type="image/png" href="https://avatars.githubusercontent.com/u/60660814?s=280&v=4">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    
    <style>
        /* ============================================================
           FONT & COLOR CONTROL CENTER
        ============================================================ */
        :root {
            --fs-header-status: 1.6rem;
            --fs-adv-btn: 0.8rem;
            --fs-toggle-text: 0.9rem;
            --fs-header-status-row: 1.15rem;
            --fs-date-line: 1.3rem;
            --fs-date-zones: 1.1rem;
            --fs-hero-time: clamp(1.5rem, 4vw, 3.8rem);
            --fs-hero-label: 1.3rem;
            --fs-adv-label: 0.85rem;
            --fs-offset-text: 1.1rem;
            --fs-map-watermark: 9vw;
            --fs-footer-name: 0.85rem;
            --fs-footer-time: 1.1rem;
            --fs-footer-date: 0.75rem;

            /* HERO SLOT COLORS */
            --color-slot-1: #FF9800; /* Vivid Amber */
            --color-slot-2: #E040FB; /* Electric Purple */
            --color-slot-3: #00E676; /* Spring Green */
            --color-default: #ffffff; /* White */

            --bg-dark: #06090f; --card-bg: #0d1117; --border: #30363d; --nws-blue: #003087;
            --danger: #da3633; --success: #00c853;
        }

        body.mode-pc {
            --fs-header-status: 1.0rem; --fs-adv-btn: 0.65rem; --fs-toggle-text: 0.75rem;
            --fs-date-line: 0.85rem; --fs-date-zones: 0.75rem; --fs-hero-time: 2.2rem;
            --fs-hero-label: 0.75rem; --fs-adv-label: 0.75rem; --fs-offset-text: 0.95rem;
            --fs-map-watermark: 6vw; --fs-footer-name: 0.7rem; --fs-footer-time: 0.95rem;
            --fs-footer-date: 0.65rem;
        }

        * { box-sizing: border-box; outline: none; }
        body { margin: 0; font-family: 'Segoe UI', Helvetica, Arial, sans-serif; background: var(--bg-dark); color: white; display: flex; flex-direction: column; height: 100vh; overflow: hidden; }

        /* STANDARD HEADER INFRASTRUCTURE */
        header { background: white; border-bottom: 4px solid var(--nws-blue); flex-shrink: 0; z-index: 1001; padding: 6px 15px 4px 15px; }
        .header-top { display: flex; align-items: center; justify-content: space-between; gap: 15px; }
        .header-top-left { display: flex; align-items: center; gap: 0px; width: 75%; }
        .logos { display: flex; align-items: center; gap: 12px; flex-shrink: 0; }
        .logos img { height: 50px; transition: height 0.2s ease; cursor: pointer; }

        /* ROW 2 METADATA STATUS CONTAINER LAYER */
        .header-status-row {
            display: flex;
            align-items: center;
            width: 100%;
            padding: 6px 0 2px 2px;
            margin-top: 4px;
            border-top: 1px solid #e1e4e8;
            font-size: var(--fs-header-status-row); 
            letter-spacing: 0.2px;
            flex-wrap: wrap;
            gap: 0px;
        }
        .status-label {
            color: #444d56;
            font-weight: 800;
            text-transform: uppercase;
        }
        .status-value-badge {
            font-weight: 900;
            text-transform: uppercase;
        }
        .status-normal { color: #00e676; }
        .status-caution { color: #ffca28; }
        .status-critical { color: #ff3b3b; font-family: 'Arial Black', sans-serif; }
        
        .ops-reason-note {
            font-size: 0.9rem;
            color: #e0c060;
            font-style: italic;
            font-weight: 800;
            border-left: 2px solid #e0c060;
            padding-left: 8px;
            margin-left: 8px;
            white-space: nowrap;
        }

        /* PREMIUM HIGH-VISIBILITY PROFILE TITLE */
        .profile-header-title {
            color: var(--nws-blue);
            font-family: 'Arial Black', 'Segoe UI Black', -apple-system, sans-serif;
            font-weight: 900;
            font-size: 2.4rem;
            line-height: 1;
            margin-left: 10px; 
            border-left: 5px solid var(--nws-blue);
            padding-left: 12px; 
            text-transform: uppercase;
            letter-spacing: -0.5px;
            align-self: center;
            white-space: pre; 
            transition: margin-left 0.15s ease;
        }

        /* NCO BANNER BASE CSS STYLING OVERRIDES */
        a.header-center-text {
            font-family: Arial, sans-serif;
            font-size: 2.0em;
            letter-spacing: 0px;
            word-spacing: -0.5px;
            text-decoration: none;
            font-weight: 550;
            color: black;
            text-transform: uppercase;
            font-variant: small-caps;
        }
        .header-center-text {
            width: 550px;
            height: 40px;
            margin-left: 4px;
            overflow: visible;
            float: left;
            padding-top: 2px;
            align-self: center;
        }

        /* NCO BANNER REPLICA MODULE */
        .header {
            display: none; background: #ffffff; width: 100%; border-bottom: 4px solid #ccc;
            position: relative; overflow: hidden; flex-direction: column; align-items: stretch; padding: 5px 15px; flex-shrink: 0; z-index: 1001;
        }
        .header-content { display: flex; align-items: center; gap: 12px; width: 100%; justify-content: space-between; }
        .nco-left-brand { display: flex; align-items: center; gap: 10px; }
        .nco-right-swoop {
            position: relative; display: flex; align-items: center; background: linear-gradient(135deg, #00a8ff, #003087);
            padding: 10px 40px 10px 60px; clip-path: polygon(25px 0%, 100% 0%, 100% 100%, 0% 100%); height: 60px;
        }

        .adv-btn { background: #eee; color: var(--nws-blue); border: 1px solid #ccc; padding: 3px 10px; border-radius: 4px; font-weight: 800; cursor: pointer; text-transform: uppercase; font-size: var(--fs-adv-btn); }

        /* TIME NOT CURRENT warning */
        #time-not-current-banner {
            display: none;
            position: fixed; top: 0; left: 0; width: 100%; z-index: 9999;
            background: rgba(218, 54, 51, 0.65);
            color: white; text-align: center;
            font-weight: 900; font-size: 1rem; letter-spacing: 4px;
            padding: 6px 0; text-transform: uppercase;
            pointer-events: none;
        }
        #map-time-watermark {
            display: none;
            position: absolute; top: 50%; left: 45%;
            transform: translate(-50%, -50%) rotate(-25deg);
            font-size: 7vw;
            font-weight: 900; color: rgba(218,54,51,0.28);
            text-transform: uppercase; letter-spacing: 4px;
            pointer-events: none; z-index: 500;
            white-space: nowrap; text-align: center; line-height: 1.3;
        }
        .sync-status { display: flex; align-items: center; gap: 5px; font-size: 0.65rem; font-weight: 900; color: var(--nws-blue); margin-left: 5px; text-transform: uppercase; flex-shrink: 0; }
        .sync-dot { width: 8px; height: 8px; border-radius: 50%; background: #999; }
        .sync-dot.synced { background: var(--success); }
        .sync-dot.offline { background: var(--danger); }

        .header-bottom { display: flex; justify-content: flex-end; padding-bottom: 2px; background: #ffffff; padding-right: 15px; border-bottom: 1px solid #ccc; }
        #local-date-display { display: flex; flex-direction: row; gap: 8px; flex-wrap: wrap; justify-content: flex-end; }
        .date-block { display: flex; flex-direction: column; align-items: center; justify-content: center; border: 2px solid var(--nws-blue); padding: 2px 10px; border-radius: 6px; background-color: rgba(0, 48, 135, 0.03); }
        .date-line { text-transform: uppercase; color: var(--nws-blue); font-weight: 900; font-size: var(--fs-date-line); line-height: 1; margin-bottom: 2px; }
        .date-zones { font-weight: 900; color: var(--nws-blue); opacity: 0.9; font-size: var(--fs-date-zones); line-height: 1.1; letter-spacing: 1px; }

        #adv-panel { background: #0d1117; padding: 10px 15px; display: none; align-items: center; gap: 15px; border-bottom: 1px solid var(--border); flex-shrink: 0; z-index: 1000; flex-wrap: wrap; }
        .control-group { display: flex; align-items: center; gap: 8px; font-weight: bold; color: var(--color-slot-2); font-size: var(--fs-adv-label); }
        .zone-sel, .profile-select, .station-txt-input { border: 1.5px solid var(--color-slot-2); background: black; color: white; border-radius: 4px; padding: 2px; text-align: center; font-weight: bold; }
        input[type=range] { flex-grow: 1; accent-color: var(--color-slot-2); cursor: pointer; min-width: 100px; }
        #offset-display { font-family: monospace; font-weight: bold; color: white; min-width: 40px; text-align: center; font-size: var(--fs-offset-text); }

        /* POPUP SETTINGS MODAL INTERFACE PANELS */
        .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.75); z-index: 2000; align-items: center; justify-content: center; overflow: hidden; }
        .modal-content { background: #0d1117; border: 1px solid var(--border); border-radius: 12px; width: 540px; max-width: 95%; max-height: 92vh; padding: 20px; display: flex; flex-direction: column; gap: 15px; box-shadow: 0 8px 32px rgba(0,0,0,0.5); }
        .modal-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); padding-bottom: 10px; }
        .modal-title { font-size: 1.2rem; font-weight: 800; color: #fff; }
        .modal-close { cursor: pointer; font-size: 1.4rem; color: #8b949e; font-weight: bold; }
        .modal-body { display: flex; flex-direction: column; gap: 13px; overflow-y: auto; padding-right: 5px; }
        .modal-row { display: flex; align-items: center; justify-content: space-between; background: #161b22; padding: 10px; border-radius: 6px; border: 1px solid #21262d; gap: 10px; }
        .modal-row.vertical { flex-direction: column; align-items: flex-start; gap: 8px; }
        .modal-label { font-weight: bold; font-size: 0.85rem; color: #c9d1d9; }
        
        .zone-checkbox-grid { display: grid; grid-template-columns: repeat(3, 160px); gap: 8px; width: 100%; margin-top: 4px; }
        .zone-check-label { display: flex; align-items: center; gap: 6px; font-size: 0.8rem; cursor: pointer; color: #c9d1d9; }
        .zone-check-label input { accent-color: var(--color-slot-2); cursor: pointer; }

        .color-pickers-group { display: flex; gap: 8px; }
        .color-picker-wrapper { display: flex; flex-direction: column; align-items: center; gap: 2px; font-size: 0.7rem; color: #8b949e; }
        .color-picker-input { width: 30px; height: 30px; border: none; background: transparent; cursor: pointer; padding: 0; }
        .station-txt-input { width: 180px; border: 1.5px solid var(--color-slot-2); border-radius: 4px; background: black; color: white; padding: 4px; font-weight: bold; text-align: left; }
        .tab-logo { height: 14px; display: none; vertical-align: middle; margin-right: 4px; }

        .switch { position: relative; display: inline-block; width: 40px; height: 20px; flex-shrink: 0; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #444; transition: .3s; border-radius: 20px; border: 1px solid #555; }
        .slider:before { position: absolute; content: ""; height: 12px; width: 12px; left: 2px; bottom: 2px; background-color: white; transition: .3s; border-radius: 50%; }
        input:checked + .slider { background-color: var(--nws-blue); border-color: #58a6ff; }
        input:checked + .slider:before { transform: translateX(20px); }

        .toggle-options-wrapper { display: flex; align-items: center; gap: 8px; font-weight: bold; font-size: 0.8rem; color: #c9d1d9; }
        .toggle-label-text { font-weight: 800; color: #fff; }
        .zoom-input { width: 55px; text-align: center; }

        .hero { display: grid; gap: 8px; padding: 4px 10px; flex-shrink: 0; transition: all 0.3s ease; }
        .card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 8px; padding: 10px; text-align: center; border-top: 5px solid #8b949e; }
        .big-time { font-family: monospace; font-weight: 800; line-height: 1; margin: 0; font-size: var(--fs-hero-time); text-shadow: none !important; }
        .label-mini { letter-spacing: 1px; font-weight: bold; font-size: var(--fs-hero-label); margin-bottom: 4px; text-shadow: none !important; }

        #map-wrapper { flex-grow: 1; position: relative; width: 100%; overflow: hidden; }
        #map { height: 100%; width: 100%; background: #0b0f14; }

        .footer { display: flex; gap: 4px; padding: 4px; background: #080a0f; flex-shrink: 0; overflow-x: auto; width: 100%; }
        .tab { background: var(--card-bg); border: 1px solid var(--border); padding: 4px; text-align: center; border-radius: 5px; transition: all 0.2s ease; border-bottom: 3px solid transparent; flex: 1; min-width: 90px; }
        .tab-name { color: #8b949e; font-weight: 800; text-transform: uppercase; font-size: var(--fs-footer-name); display: flex; align-items: center; justify-content: center; }
        .tab-time { font-weight: bold; font-family: monospace; margin: 0; font-size: var(--fs-footer-time); color: white; text-shadow: none !important; }
        .tab-date { font-weight: bold; font-size: var(--fs-footer-date); color: #8b949e; }

        /* THEMED HIGH-CONTRAST CONSOLE TOOLTIPS MAP BOXES OVERRIDES */
        .leaflet-tooltip-custom { 
            background: rgba(13, 17, 23, 0.97) !important; 
            color: #ffffff !important; 
            border-radius: 6px; 
            padding: 4px 12px !important; 
            min-width: 110px; 
            box-shadow: 0 4px 20px rgba(0,0,0,0.9), 0 0 0 1px rgba(0,229,255,0.15) !important;
            display: flex !important; 
            flex-direction: column !important; 
            align-items: center !important; 
            justify-content: center !important; 
            text-align: center !important; 
            pointer-events: none; 
            border: 1.5px solid rgba(150,180,200,0.5) !important;
        }
        .tooltip-name { color: #ffffff; text-transform: uppercase; border-bottom: 1px solid #30363d; padding-bottom: 2px; margin-bottom: 3px; font-weight: 800; width: 100%; font-size: calc(0.85rem * var(--map-clock-scale, 1)); text-shadow: none !important; }
        .tooltip-time { font-family: monospace; font-weight: 900; line-height: 1; font-size: calc(1.5rem * var(--map-clock-scale, 1)); text-shadow: none !important; }
    .upcoming-day-tab {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.12);
        color: #8b949e;
        padding: 3px 10px;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 1px;
    }
    .modal-tab-active {
        background: rgba(30,126,173,0.2) !important;
        border-color: #1e7ead !important;
        color: #58c4f5 !important;
    }
    /* ── STATUS MODE ─────────────────────────────────────────── */
    .status-day-tab {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.15);
        color: #8b949e;
        padding: 6px 16px;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 1px;
        transition: all 0.15s;
    }
    .status-day-tab.active-tab {
        background: rgba(30,126,173,0.25);
        border-color: #1e7ead;
        color: #58c4f5;
    }
    .status-shift-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px;
        padding: 12px 14px;
    }
    .status-shift-time {
        font-size: 0.82rem;
        color: #8b949e;
        margin-bottom: 6px;
        font-weight: 700;
        letter-spacing: 1px;
    }
    .status-person-row {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 4px;
        font-size: 0.85rem;
    }
    .status-role-badge {
        font-size: 0.65rem;
        padding: 1px 6px;
        border-radius: 10px;
        font-weight: 700;
        letter-spacing: 1px;
        background: rgba(88,196,245,0.15);
        color: #58c4f5;
        border: 1px solid rgba(88,196,245,0.3);
        white-space: nowrap;
    }
    .status-role-badge.lead { background:rgba(240,160,0,0.15); color:#f0a000; border-color:rgba(240,160,0,0.3); }
    .status-role-badge.fim  { background:rgba(46,168,74,0.15);  color:#2ea84a; border-color:rgba(46,168,74,0.3);  }
    /* ── CLOCK PICKER ────────────────────────────────────────── */
    #clock-picker-overlay {
        position: fixed; top:0; left:0; width:100%; height:100%;
        z-index: 9999; pointer-events: none;
    }
    #clock-picker {
        position: fixed;
        background: #1c2128;
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 12px;
        padding: 14px;
        z-index: 10000;
        box-shadow: 0 8px 32px rgba(0,0,0,0.6);
        width: 220px;
        display: none;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        pointer-events: all;
    }
    .clock-face {
        position: relative;
        width: 160px;
        height: 160px;
        border-radius: 50%;
        background: #0d1117;
        border: 2px solid rgba(255,255,255,0.1);
        cursor: pointer;
    }
    .clock-number {
        position: absolute;
        font-size: 0.78rem;
        font-weight: 700;
        color: #ccc;
        width: 22px;
        height: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        transform: translate(-50%, -50%);
        cursor: pointer;
        transition: background 0.1s;
    }
    .clock-number:hover, .clock-number.selected { background: #1e7ead; color: #fff; }
    .clock-hand {
        position: absolute;
        bottom: 50%;
        left: 50%;
        transform-origin: bottom center;
        border-radius: 4px;
        pointer-events: none;
    }
    .clock-center {
        position: absolute;
        top: 50%; left: 50%;
        width: 8px; height: 8px;
        background: #58c4f5;
        border-radius: 50%;
        transform: translate(-50%,-50%);
        pointer-events: none;
    }
    #clock-time-display {
        font-size: 1.5rem;
        font-weight: 900;
        color: #fff;
        letter-spacing: 2px;
        font-variant-numeric: tabular-nums;
    }
    .clock-ampm-row { display: flex; gap: 6px; }
    .clock-ampm-btn {
        padding: 4px 14px;
        border-radius: 4px;
        border: 1px solid #444;
        background: transparent;
        color: #8b949e;
        font-size: 0.8rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.1s;
    }
    .clock-ampm-btn.active { background: #1e7ead; border-color: #58c4f5; color: #fff; }
    .clock-mode-label {
        font-size: 0.65rem;
        color: #8b949e;
        letter-spacing: 2px;
    }
    </style>
</head>

<body class="mode-situation">

    <!-- TIME NOT CURRENT BANNER -->
    <div id="time-not-current-banner">⚠ TIME NOT CURRENT — SIMULATED OFFSET ACTIVE</div>

<div id="dynamic-header-wrapper">
    <header id="standard-header">
        <div class="header-top">
            <div class="header-top-left">
                <div class="logos">
                    <a href="https://www.noaa.gov" target="_blank"><img id="noaa-logo" src="https://water.noaa.gov/assets/styles/public/images/noaa-logo.svg" alt="NOAA Portal"></a>
                    <a href="https://www.weather.gov" target="_blank"><img id="nws-logo" src="https://water.noaa.gov/assets/styles/public/images/nws-logo.svg" alt="NWS Portal"></a>
                    <img id="owp-main-logo" src="https://water.noaa.gov/assets/styles/public/images/nav-logo-blue.png" alt="OWP Portal" style="display:none;" onclick="window.open('https://water.noaa.gov/', '_blank')">
                </div>
                
                <div id="header-profile-title" class="profile-header-title" style="display: none;"></div>
                
                <button class="adv-btn" onclick="toggleAdv()" style="margin-left: 15px;">ADVANCED</button>
                <div class="sync-status">
                    <div id="sync-dot" class="sync-dot"></div>
                    <span id="sync-text">SYNCING...</span>
                </div>
            </div>
            <div class="toggle-container" id="standard-cycle-toggle-box" style="display: none;">
                <input type="checkbox" id="time-toggle" checked>
            </div>
        </div>
        
        <div class="header-status-row">
            <div id="nco-status-container" style="display: none; align-items: center; margin-right: 25px;">
                <span class="status-label">CURRENT NCO STATUS:</span>
                <span id="nco-status-value" class="status-value-badge status-normal" style="margin-left: 6px;">SYNCING...</span>
            </div>
            
            <div id="nwc-ops-level-container" style="display: none; align-items: center; flex-wrap: wrap; gap: 4px;">
                <span class="status-label" id="ops-level-bar-label">NWC OPS LEVEL:</span>
                <span id="nwc-ops-value" class="status-value-badge status-normal" style="margin-left: 6px;">Level 4</span>
                <span id="nwc-ops-reason" class="ops-reason-note" style="display: none;"></span>
            </div>
        </div>
    </header>

    <div class="header" id="nco-header-banner">
        <div class="header-content">
            <div class="nco-left-brand">
                <a href="https://www.noaa.gov" title="Explore other NOAA products" class="header-noaa-icon" target="_blank">
                    <img src="https://water.noaa.gov/assets/styles/public/images/noaa-logo.svg" alt="NOAA Logo" height="55">
                </a>
                <a href="https://www.weather.gov" title="Access to the latest watches and warnings" class="header-nws-icon" target="_blank">
                    <img src="https://water.noaa.gov/assets/styles/public/images/nws-logo.svg" alt="NWS Logo" height="55">
                </a>
                <a href="#contents"><img height="1" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" alt="Skip Navigation Links" width="1"></a>
                <a href="https://www.ncep.noaa.gov/" target="_blank" class="header-center-text">NCEP Central Operations</a>
            </div>
            <div style="display: flex; align-items: center; gap: 15px;">
                <button class="adv-btn" style="border-color:#7f8c8d;" onclick="toggleAdv()">ADVANCED</button>
                <div class="nco-right-swoop">
                    <img src="https://water.noaa.gov/assets/styles/public/images/noaa-logo.svg" height="35" style="filter: brightness(0) invert(1);" alt="Emblem">
                </div>
            </div>
        </div>
        <div class="header-status-row" style="border-top: 1px solid #ccc; padding-left: 2px;">
            <div id="nco-status-container-nco" style="display: flex; align-items: center; margin-right: 25px;">
                <span class="status-label">CURRENT NCO STATUS:</span>
                <span id="nco-status-value-nco" class="status-value-badge status-normal" style="margin-left: 6px;">SYNCING...</span>
            </div>

            <div id="nco-nwc-ops-level-container" style="display: none; align-items: center; flex-wrap: wrap; gap: 4px;">
                <span class="status-label" id="ops-level-banner-label">NWC OPS LEVEL:</span>
                <span id="nwc-ops-value-banner" class="status-value-badge status-normal" style="margin-left: 6px;">Level 4</span>
                <span id="nco-nwc-ops-reason-nco" class="ops-reason-note" style="display: none;"></span>
            </div>
        </div>
    </div>
</div>

<div class="header-bottom">
    <div id="local-date-display">--</div>
</div>

<div id="adv-panel">
    <div class="control-group" style="flex-grow:1;">
        <span>TIME ADJ</span>
        <input type="range" id="time-slider" min="-25" max="25" step="1" value="0">
        <div id="offset-display">LIVE</div>
    </div>
    <button class="adv-btn" style="background:#58a6ff; color:black; border:none;" onclick="openModal()">SETTINGS POPUP ⓘ</button>
    <button class="adv-btn" style="background:var(--danger); color:white; border:none;" onclick="resetTime()">RESET TIME</button>
</div>

<div id="settings-modal" class="modal-overlay">
    <div class="modal-content">
        <div class="modal-header">
            <div class="modal-title">System Configuration Controls</div>
            <div class="modal-close" onclick="closeModal()">×</div>
        </div>
        <div class="modal-body">
            <!-- URL-locked office banner (shown when ?OFFICEID is in URL) -->
            <div id="url-office-banner" style="display:none; align-items:center; justify-content:center; padding:6px 10px; background:rgba(0,180,100,0.08); border:1px solid rgba(0,180,100,0.3); border-radius:5px; margin-bottom:4px;">
                <span style="color:#00c864; font-size:0.82rem; font-weight:700; letter-spacing:1px;" id="url-office-banner-label">OHRFC — Ohio RFC</span>
                <span style="color:#8b949e; font-size:0.72rem; margin-left:8px;">URL-locked profile</span>
            </div>
            <div class="modal-row" id="profile-selector-row" style="display:none;">
                <div class="modal-label">Operational Profile:</div>
                <select id="profile-selector" class="profile-select" onchange="handleProfileChange()">
                    <option value="OWP">Office of Water Prediction (OWP)</option>
                    <option value="NWC" selected>NWC Operations</option>
                    <option value="RFC_OWP">River Forecast Center (OWP)</option>
                    <option value="WFO">Weather Forecast Office (WFO)</option>
                    <option value="NCO">NCEP Central Operations (NCO)</option>
                </select>
            </div>
            <div class="modal-row" id="node-id-container" style="display: none;">
                <div class="modal-label" id="node-id-label">Node Identifier:</div>
                <input type="text" id="station-identifier" class="station-txt-input" placeholder="e.g. Lubbock / LUB" oninput="handleIdentifierInput()">
            </div>


            <div id="wpod-auth-gate" class="modal-row vertical" style="display: none; background: rgba(218, 54, 51, 0.05); border-color: rgba(218, 54, 51, 0.25);">
                <div class="modal-label" style="color: #ff6b6b;" id="office-auth-label">NWC Operational Security Key Required:</div>
                <div style="display: flex; gap: 8px; width: 100%;">
                    <input type="password" id="wpod-password-input" class="station-txt-input" style="flex-grow: 1; text-align: left;" placeholder="Enter Security Code" onkeydown="if(event.key==='Enter') validateOfficeAuth()">
                    <button class="adv-btn" style="background: var(--nws-blue); color: white; border: none;" onclick="validateOfficeAuth()">Unlock</button>
                </div>
            </div>

            <!-- ── CHANGE PASSWORD — always accessible, no unlock required ── -->
            <div id="office-change-password-section" style="display:none; flex-direction:column; gap:4px; width:100%; padding:4px 0;">
                <button onclick="toggleChangePasswordUI()" style="background:transparent; border:1px solid #333; color:#8b949e; border-radius:4px; padding:3px 10px; font-size:0.75rem; cursor:pointer; align-self:flex-start;">🔑 Change Password</button>
                <div id="change-password-form" style="display:none; flex-direction:column; gap:6px; background:rgba(255,255,255,0.04); border:1px solid #333; border-radius:6px; padding:10px; margin-top:2px;">
                    <div style="font-size:0.72rem; color:#8b949e; letter-spacing:1px;">CHANGE PASSWORD</div>
                    <input type="password" id="current-password-input" class="station-txt-input" style="width:100%; text-align:left;" placeholder="Current password" autocomplete="current-password">
                    <input type="password" id="new-password-input" class="station-txt-input" style="width:100%; text-align:left;" placeholder="New password" autocomplete="new-password">
                    <input type="password" id="confirm-password-input" class="station-txt-input" style="width:100%; text-align:left;" placeholder="Confirm new password" autocomplete="new-password">
                    <button onclick="submitPasswordChange()" style="background:#1a4e6e; border:2px solid #1e7ead; color:white; padding:6px 16px; border-radius:5px; cursor:pointer; font-size:0.82rem; font-weight:700; letter-spacing:1px;">UPDATE PASSWORD</button>
                    <div id="change-password-status" style="font-size:0.75rem; color:#8b949e; text-align:center;"></div>
                </div>
            </div>

            <div id="nwc-secure-controls" style="display: none; flex-direction: column; gap: 13px;">

                <!-- NCO: optional ops level toggle (hidden for all other offices) -->
                <div id="nco-ops-toggle-row" style="display:none; align-items:center; gap:10px; padding:6px 0; border-bottom:1px solid rgba(255,255,255,0.08);">
                    <label style="display:flex; align-items:center; gap:8px; cursor:pointer; font-size:0.85rem; color:#ccc;">
                        <input type="checkbox" id="nco-ops-enabled-checkbox" onchange="handleNCOOpsToggle()">
                        Enable Ops Status Level
                    </label>
                    <span style="font-size:0.72rem; color:#8b949e;">— leave unchecked for CWD display only</span>
                </div>

                <!-- Ops level (hidden for NCO unless toggled on) -->
                <div id="nwc-ops-level-row" class="modal-row">
                    <div class="modal-label" id="ops-level-label">OPS Activation Level:</div>
                    <select id="nwc-ops-level-selector" class="profile-select" onchange="handleNWCOpsLevelChange()">
                        <option value="Level 4">Level 4 (Normal Operations)</option>
                        <option value="Level 3">Level 3 (Enhanced Operations)</option>
                        <option value="Level 2">Level 2 (Partial Activation)</option>
                        <option value="Level 1">Level 1 (Full Activation)</option>
                    </select>
                </div>

                <div class="modal-row vertical" id="nwc-reason-input-container" style="display: none;">
                    <div class="modal-label">Reason for Activation Level Escalation:</div>
                    <input type="text" id="nwc-ops-reason-input" class="station-txt-input" style="width: 100%; text-align: left; text-transform: none;" placeholder="Provide operational justification note..." autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" oninput="handleNWCOpsReasonInput()">
                </div>

                <div class="modal-row vertical" id="nwc-hours-container" style="display:none; margin-top:8px;">
                    <div class="modal-label">Hours of Operation:</div>
                    <div style="display:flex; flex-direction:column; gap:6px; width:100%;">
                        <label style="display:flex; align-items:center; gap:8px; cursor:pointer;">
                            <input type="checkbox" id="nwc-hours-default" onchange="handleHoursChange()" checked>
                            <span id="hours-default-label" style="font-size:0.85rem; color:#ccc;">Use Default</span>
                        </label>
                        <label style="display:flex; align-items:center; gap:8px; cursor:pointer;">
                            <input type="checkbox" id="nwc-hours-24hr" onchange="handleHoursChange()">
                            <span style="font-size:0.85rem; color:#ccc;">24-Hour Operations</span>
                        </label>
                        <div id="nwc-hours-custom" style="display:none; align-items:center; gap:8px; flex-wrap:wrap;">
                            <span style="font-size:0.85rem; color:#ccc;">Open:</span>
                            <input type="text" id="nwc-hours-open" class="station-txt-input" style="width:90px; text-align:center;" placeholder="5:00 AM" onfocus="openClockPicker(this)" oninput="handleHoursChange()">
                            <span style="font-size:0.85rem; color:#ccc;">Close:</span>
                            <input type="text" id="nwc-hours-close" class="station-txt-input" style="width:90px; text-align:center;" placeholder="8:30 PM" onfocus="openClockPicker(this)" oninput="handleHoursChange()">
                        </div>
                    </div>
                </div>

                <div class="modal-row" id="nwc-update-btn-container" style="display:none; margin-top:12px; justify-content:center;">
                    <button onclick="manualHydroUpdate()" style="background:#1a6e2e; border:2px solid #2ea84a; color:white; padding:10px 28px; border-radius:6px; cursor:pointer; font-size:0.9rem; font-weight:900; letter-spacing:1px; width:100%;" id="update-status-btn">
                        ▶ UPDATE STATUS
                    </button>
                    <div id="nwc-update-status" style="font-size:0.75rem; color:#8b949e; margin-top:6px; text-align:center; width:100%;"></div>
                </div>

                <!-- ── NWC STAFFING ─────────────────────────────────────── -->
                <div id="nwc-staffing-container" style="display:none; margin-top:12px; width:100%; flex-direction:column; gap:10px;">

                    <!-- ── STAFF MANAGEMENT ───────────────────────────────── -->
                    <div style="border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:10px;background:rgba(255,255,255,0.02);">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                            <div class="modal-label" style="font-size:0.78rem;color:#8b949e;letter-spacing:2px;">STAFF LIST</div>
                            <button onclick="toggleStaffMgmt()" style="background:transparent;border:1px solid #333;color:#8b949e;padding:2px 8px;border-radius:4px;font-size:0.72rem;cursor:pointer;" id="staff-mgmt-toggle">▼ Manage</button>
                        </div>

                        <!-- Compact roster display -->
                        <div id="nwc-roster-list" style="display:flex; flex-wrap:wrap; gap:6px; margin-bottom:6px;"></div>

                        <!-- Expandable add section -->
                        <div id="staff-mgmt-body" style="display:none;flex-direction:column;gap:8px;margin-top:8px;padding-top:8px;border-top:1px solid rgba(255,255,255,0.08);">

                            <!-- NWC/WFO add row -->
                            <div id="roster-add-nwc" style="display:flex; gap:6px; align-items:center; flex-wrap:wrap;">
                                <input type="text" id="nwc-roster-add-name" class="station-txt-input" style="flex:1;min-width:100px; text-align:left;" placeholder="Staff name" autocomplete="off">
                                <select id="nwc-roster-add-role" class="profile-select" style="width:150px;">
                                    <option value="Forecaster">Forecaster</option>
                                    <option value="Shift Lead">Shift Lead</option>
                                    <option value="FIM Coordinator">FIM Coordinator</option>
                                    <option value="IC">IC Eligible</option>
                                </select>
                                <button onclick="addRosterMember()" style="background:#1a6e2e;border:1px solid #2ea84a;color:white;padding:4px 12px;border-radius:4px;cursor:pointer;font-weight:700;white-space:nowrap;">+ Add</button>
                            </div>

                            <!-- RFC add block -->
                            <div id="roster-add-rfc" style="display:none; flex-direction:column; gap:6px;">
                                <div style="display:flex; gap:6px; align-items:center; flex-wrap:wrap;">
                                    <input type="text" id="rfc-roster-add-name" class="station-txt-input" style="flex:1;min-width:100px; text-align:left;" placeholder="Staff name" autocomplete="off">
                                    <select id="rfc-roster-add-role" class="profile-select" style="width:130px;">
                                        <option value="Lead Hydro">Lead Hydro</option>
                                        <option value="Hydro">Hydro</option>
                                        <option value="Lead HAS">Lead HAS</option>
                                        <option value="HAS">HAS</option>
                                    </select>
                                </div>
                                <div style="display:flex; gap:6px; align-items:center; flex-wrap:wrap;">
                                    <input type="text" id="rfc-roster-add-basin" class="station-txt-input" style="flex:1;min-width:100px; text-align:left;" placeholder="Default basin (optional)" autocomplete="off">
                                    <label style="display:flex;align-items:center;gap:5px;cursor:pointer;white-space:nowrap;font-size:0.82rem;color:#ccc;">
                                        <input type="checkbox" id="rfc-roster-add-fim"> Default FIM
                                    </label>
                                    <button onclick="addRFCRosterMember()" style="background:#1a6e2e;border:1px solid #2ea84a;color:white;padding:4px 12px;border-radius:4px;cursor:pointer;font-weight:700;white-space:nowrap;">+ Add</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Shifts -->
                    <div class="modal-label" style="margin-top:8px; margin-bottom:4px; font-size:0.8rem; color:#8b949e; letter-spacing:2px;">SHIFTS</div>

                    <!-- Custom shift types (non-NWC only) -->
                    <div id="custom-shift-types-section" style="display:none; flex-direction:column; gap:6px; margin-bottom:8px; padding:8px; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); border-radius:6px;">
                        <div style="font-size:0.7rem; color:#8b949e; letter-spacing:2px;">SHIFT TYPES <span style="font-size:0.65rem; color:#555;">(custom labels — saved per office)</span></div>
                        <div id="shift-types-list" style="display:flex; flex-wrap:wrap; gap:4px; min-height:20px;"></div>
                        <div style="display:flex; gap:6px;">
                            <input type="text" id="new-shift-type-input" class="station-txt-input" style="flex:1; text-align:left;" placeholder="New shift type name (e.g. Day Hydro)" autocomplete="off">
                            <button onclick="addCustomShiftType()" style="background:#1a4e6e; border:1px solid #1e7ead; color:white; padding:4px 12px; border-radius:4px; cursor:pointer; font-size:0.8rem; white-space:nowrap;">+ Add</button>
                        </div>
                    </div>

                    <!-- RFC Basin List (RFC only) -->
                    <div id="basin-list-section" style="display:none; flex-direction:column; gap:6px; margin-bottom:8px; padding:8px; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); border-radius:6px;">
                        <div style="font-size:0.7rem; color:#8b949e; letter-spacing:2px;">BASIN LIST <span style="font-size:0.65rem; color:#555;">(select from these when assigning shifts)</span></div>
                        <div id="basin-list-tags" style="display:flex; flex-wrap:wrap; gap:4px; min-height:20px;"></div>
                        <div style="display:flex; gap:6px;">
                            <input type="text" id="new-basin-input" class="station-txt-input" style="flex:1; text-align:left;" placeholder="Basin name (e.g. Upper Ohio, Muskingum)" autocomplete="off"
                                onkeydown="if(event.key==='Enter') addBasinToList()">
                            <button onclick="addBasinToList()" style="background:#1a4e6e; border:1px solid #1e7ead; color:white; padding:4px 12px; border-radius:4px; cursor:pointer; font-size:0.8rem; white-space:nowrap;">+ Add</button>
                        </div>
                    </div>

                    <div id="nwc-shifts-list" style="display:flex; flex-direction:column; gap:8px;"></div>
                    <button onclick="addShift()" style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.2); color:white; padding:6px 12px; border-radius:4px; cursor:pointer; font-size:0.8rem; margin-top:4px; width:100%;">+ Add Shift</button>

                    <!-- BACKUP RELATIONSHIPS -->
                    <div id="backup-section" style="margin-top:12px; border-top:1px solid rgba(255,255,255,0.1); padding-top:10px; display:none; flex-direction:column; gap:10px;">
                        <div class="modal-label" style="font-size:0.8rem; color:#8b949e; letter-spacing:2px;">BACKUP STATUS</div>

                        <!-- Backing Up -->
                        <div>
                            <div style="font-size:0.75rem; color:#6cb4e4; font-weight:700; letter-spacing:1px; margin-bottom:6px;">▶ BACKING UP:</div>
                            <div id="backing-up-list" style="display:flex; flex-direction:column; gap:4px; margin-bottom:6px;"></div>
                            <div style="display:flex; gap:6px; flex-wrap:wrap;">
                                <input type="text" id="backing-up-office" class="station-txt-input" style="width:100px; text-align:left;" placeholder="Office (e.g. MARFC)" autocomplete="off">
                                <input type="text" id="backing-up-reason" class="station-txt-input" style="flex:1; min-width:120px; text-align:left;" placeholder="Reason" autocomplete="off">
                                <button onclick="addBackupEntry('up')" style="background:#1a4060; border:1px solid #1e6ea8; color:white; padding:4px 12px; border-radius:4px; cursor:pointer; font-size:0.8rem; white-space:nowrap;">+ Add</button>
                            </div>
                        </div>

                        <!-- Backed Up By -->
                        <div>
                            <div style="font-size:0.75rem; color:#2ea84a; font-weight:700; letter-spacing:1px; margin-bottom:6px;">◀ BACKED UP BY:</div>
                            <div id="backed-up-by-list" style="display:flex; flex-direction:column; gap:4px; margin-bottom:6px;"></div>
                            <div style="display:flex; gap:6px; flex-wrap:wrap;">
                                <input type="text" id="backed-up-by-office" class="station-txt-input" style="width:100px; text-align:left;" placeholder="Office (e.g. OHRFC)" autocomplete="off">
                                <input type="text" id="backed-up-by-reason" class="station-txt-input" style="flex:1; min-width:120px; text-align:left;" placeholder="Reason" autocomplete="off">
                                <button onclick="addBackupEntry('by')" style="background:#1a4060; border:1px solid #2ea84a; color:white; padding:4px 12px; border-radius:4px; cursor:pointer; font-size:0.8rem; white-space:nowrap;">+ Add</button>
                            </div>
                        </div>
                    </div>

                    <!-- OPERATIONAL FORECAST (Tomorrow + Day 3 + Day 4) -->
                    <div style="margin-top:12px; border-top:1px solid rgba(255,255,255,0.1); padding-top:10px;">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px; flex-wrap:wrap; gap:6px;">
                            <div class="modal-label" style="font-size:0.8rem; color:#8b949e; letter-spacing:2px;">OPERATIONAL FORECAST</div>
                            <div style="display:flex; gap:4px; flex-wrap:wrap;">
                                <button class="upcoming-day-tab modal-tab-active" onclick="switchForecastDay(1)" id="forecast-tab-1">TOMORROW</button>
                                <button class="upcoming-day-tab" onclick="switchForecastDay(2)" id="forecast-tab-2"></button>
                                <button class="upcoming-day-tab" onclick="switchForecastDay(3)" id="forecast-tab-3"></button>
                            </div>
                        </div>

                        <div id="forecast-panel-1">
                            <div style="display:flex; flex-direction:column; gap:8px;">
                                <div class="modal-row">
                                    <div class="modal-label" style="font-size:0.82rem;">Ops Level:</div>
                                    <select id="forecast-level-1" class="profile-select" onchange="saveForecastDay(1)">
                                        <option value="">-- Not set --</option>
                                        <option value="Level 4">Level 4 (Normal)</option>
                                        <option value="Level 3">Level 3 (Enhanced)</option>
                                        <option value="Level 2">Level 2 (Partial Activation)</option>
                                        <option value="Level 1">Level 1 (Full Activation)</option>
                                    </select>
                                </div>
                                <div class="modal-row vertical">
                                    <div class="modal-label" style="font-size:0.82rem;">Reason / Outlook:</div>
                                    <input type="text" id="forecast-reason-1" class="station-txt-input" style="width:100%; text-align:left;" placeholder="e.g. Frontal system expected" oninput="saveForecastDay(1)">
                                </div>
                                <div class="modal-row">
                                    <div class="modal-label" style="font-size:0.82rem;">Expected QPF:</div>
                                    <input type="text" id="forecast-qpf-1" class="station-txt-input" style="flex:1; text-align:left;" placeholder="e.g. 1.5–2.5 in" oninput="saveForecastDay(1)">
                                </div>
                            </div>
                        </div>
                        <div id="forecast-panel-2" style="display:none;">
                            <div style="display:flex; flex-direction:column; gap:8px;">
                                <div class="modal-row">
                                    <div class="modal-label" style="font-size:0.82rem;">Ops Level:</div>
                                    <select id="forecast-level-2" class="profile-select" onchange="saveForecastDay(2)">
                                        <option value="">-- Not set --</option>
                                        <option value="Level 4">Level 4 (Normal)</option>
                                        <option value="Level 3">Level 3 (Enhanced)</option>
                                        <option value="Level 2">Level 2 (Partial Activation)</option>
                                        <option value="Level 1">Level 1 (Full Activation)</option>
                                    </select>
                                </div>
                                <div class="modal-row vertical">
                                    <div class="modal-label" style="font-size:0.82rem;">Reason / Outlook:</div>
                                    <input type="text" id="forecast-reason-2" class="station-txt-input" style="width:100%; text-align:left;" placeholder="e.g. Residual flooding risk" oninput="saveForecastDay(2)">
                                </div>
                                <div class="modal-row">
                                    <div class="modal-label" style="font-size:0.82rem;">Expected QPF:</div>
                                    <input type="text" id="forecast-qpf-2" class="station-txt-input" style="flex:1; text-align:left;" placeholder="e.g. 0.5–1.0 in" oninput="saveForecastDay(2)">
                                </div>
                            </div>
                        </div>
                        <div id="forecast-panel-3" style="display:none;">
                            <div style="display:flex; flex-direction:column; gap:8px;">
                                <div class="modal-row">
                                    <div class="modal-label" style="font-size:0.82rem;">Ops Level:</div>
                                    <select id="forecast-level-3" class="profile-select" onchange="saveForecastDay(3)">
                                        <option value="">-- Not set --</option>
                                        <option value="Level 4">Level 4 (Normal)</option>
                                        <option value="Level 3">Level 3 (Enhanced)</option>
                                        <option value="Level 2">Level 2 (Partial Activation)</option>
                                        <option value="Level 1">Level 1 (Full Activation)</option>
                                    </select>
                                </div>
                                <div class="modal-row vertical">
                                    <div class="modal-label" style="font-size:0.82rem;">Reason / Outlook:</div>
                                    <input type="text" id="forecast-reason-3" class="station-txt-input" style="width:100%; text-align:left;" placeholder="e.g. Drying conditions" oninput="saveForecastDay(3)">
                                </div>
                                <div class="modal-row">
                                    <div class="modal-label" style="font-size:0.82rem;">Expected QPF:</div>
                                    <input type="text" id="forecast-qpf-3" class="station-txt-input" style="flex:1; text-align:left;" placeholder="e.g. <0.25 in" oninput="saveForecastDay(3)">
                                </div>
                            </div>
                        </div>

                        <!-- Tomorrow shifts still accessible for activation -->
                        <div style="margin-top:8px; border-top:1px solid rgba(255,255,255,0.06); padding-top:6px; display:flex; justify-content:flex-end;">
                            <button id="activate-tomorrow-btn" onclick="activateTomorrow()" style="background:#1a4a8a; border:1px solid #3a6aaa; color:white; padding:4px 12px; border-radius:4px; cursor:pointer; font-size:0.75rem; display:none;">▶ Activate Tomorrow Shifts</button>
                        </div>
                        <!-- Keep hidden tomorrow/day3/day4 shift lists for JS compatibility -->
                        <div id="nwc-tomorrow-shifts-list" style="display:none;"></div>
                        <div id="nwc-day3-shifts-list" style="display:none;"></div>
                        <div id="nwc-day4-shifts-list" style="display:none;"></div>
                    </div>

                    <!-- FIM Coordinator -->
                    <div id="nwc-fim-container" style="display:none; flex-direction:column; gap:6px; margin-top:8px;">
