        writeHydroStatus();
    }
    // Staffing always visible after unlock
    if (staffingContainer) staffingContainer.style.display = "flex";
    // Update reason placeholder based on level
    var reasonInput = document.getElementById('nwc-ops-reason-input');
    if (activeLevel === "Level 1") reasonInput.placeholder = "Describe the national emergency requiring Full Activation...";
    else if (activeLevel === "Level 2") reasonInput.placeholder = "Describe the event requiring Partial Activation...";
    else if (activeLevel === "Level 3") reasonInput.placeholder = "Describe the event requiring Enhanced Operations...";
    
    applyNWCOpsLevelUI();
