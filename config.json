async function syncOfficialTime() {
    const dot = document.getElementById('sync-dot');
    const text = document.getElementById('sync-text');
    try {
        const response = await fetch('https://timeapi.io/api/Time/current/zone?timeZone=UTC', { signal: AbortSignal.timeout(3000) });
        const data = await response.json();
        networkOffset = Date.UTC(data.year, data.month - 1, data.day, data.hour, data.minute, data.seconds, data.milliSeconds) - Date.now();
        if (dot) dot.className = 'sync-dot synced'; 
        if (text) text.innerText = 'SYNCED';
    } catch (e) {
        if(networkOffset === 0) dot.className = 'sync-dot offline';
        if (text) text.innerText = 'LOCAL';
    }
}

function buildMatrixCheckboxes() {
    const matrixGrid = document.getElementById('zone-checkbox-matrix');
    if (!matrixGrid) return;
    matrixGrid.innerHTML = '';
    
    zoneOrder.forEach(id => {
        const lbl = document.createElement('label');
        lbl.className = 'zone-check-label';
        const checkedStatus = visibleTimeZones.includes(id) ? 'checked' : '';
        lbl.innerHTML = `
            <input type="checkbox" value="${id}" ${checkedStatus} onchange="toggleZoneVisibility('${id}', this)">
            <span>${zoneNames[id]}</span>
        `;
        matrixGrid.appendChild(lbl);
    });
}

function toggleZoneVisibility(id, cb) {
    if (cb.checked) {
        if (!visibleTimeZones.includes(id)) visibleTimeZones.push(id);
    } else {
        visibleTimeZones = visibleTimeZones.filter(z => z !== id);
        activeHeroZones = activeHeroZones.map(hz => hz === id ? 'none' : hz);
        if (customFrameConfig.homeTZ === id) {
            customFrameConfig.homeTZ = "none";
            document.getElementById('home-tz-selector').value = "none";
        }
    }
    rebuildUIContainers();
    saveSettings();
}

function rebuildUIContainers() {
    initSelectors();
    
    zoneOrder.forEach(id => {
        if (markerData[id]) {
            if (visibleTimeZones.includes(id)) {
                if (!markers[id]) {
                    const icon = L.divIcon({ className: 'custom-icon', html: `<div style="background:white; width:10px; height:10px; border-radius:50%; border:1.5px solid #333;"></div>`, iconSize: [10, 10], iconAnchor: [5, 5] });
                    const pos = getEffectiveMarkerPos(id);
                    markers[id] = L.marker(pos, { icon: icon, draggable: isPCMode }).addTo(map).bindTooltip("", { permanent: true, direction: 'top', className: 'leaflet-tooltip-custom', offset: [0, -10] });
                    // Save position on drag (PC = local only, SD = local, dispatched on SAVE CACHE)
                    markers[id].on('dragend', (function(zoneId) {
                        return function(e) {
                            var latlng = e.target.getLatLng();
                            var mode = isPCMode ? 'pc' : 'sd';
                            var positions = getMarkerPositions(mode);
                            positions[zoneId] = { lat: latlng.lat, lng: latlng.lng };
                            saveMarkerPositions(mode, positions);
                            if (mode === 'sd') refreshCustomPositionsUI();
                        };
                    })(id));
                }
            } else {
                if (markers[id]) {
                    map.removeLayer(markers[id]);
                    delete markers[id];
                }
                if (lastTooltipMinutesCache[id]) delete lastTooltipMinutesCache[id];
            }
        }
    });

    const footer = document.getElementById("footer-container");
    if (footer) {
        footer.innerHTML = '';
        zoneOrder.forEach(id => {
            if (visibleTimeZones.includes(id)) {
                const div = document.createElement("div"); div.className = `tab f-${id}`;
                div.innerHTML = `<div class="tab-name"><img src="https://water.noaa.gov/assets/styles/public/images/nws-logo.svg" class="tab-logo" id="tab-logo-${id}"><span id="foot-title-txt-${id}">${zoneNames[id]}</span> <span id="f-${id}-abbr"></span></div><div class="tab-time" id="f-${id}-t">--</div><div class="tab-date" id="f-${id}-d">--</div>`;
                footer.appendChild(div);
            }
        });
    }

    handleProfileChange();
}

function handleHomeGPSInput() {
    const latVal = document.getElementById('home-lat-input').value;
