// CWD data cache
var cwdData = null;

function hazardIconsClock(hazards) {
    if(!hazards || !hazards.length) return '';
    return hazards.map(function(h) {
        return '<img src="https://www.nco.ncep.noaa.gov/status/css/images/icon-' + h + '.png" style="width:20px; height:20px; vertical-align:middle;" alt="' + h + '">';
    }).join(' ');
}

function shortStatusClock(s) {
    if(!s) return '';
    var u = (s || '').toUpperCase();
    if(u.includes('CRITICAL') || u.includes('CWD')) return 'CWD';
    if(u.includes('CAUTION') || u.includes('ECE')) return 'EC';
    return 'NORMAL';
}

async function fetchLiveNCOStatus() {
    try {
        const response = await fetch((window._GITLAB_CDN || 'https://cdn.jsdelivr.net/gh/glen104/nwc-status@main/') + 'status.json?t=' + Math.floor(Date.now()/5000), 
            { signal: AbortSignal.timeout(8000) });
        if (response.ok) {
            const data = await response.json();
            cwdData = data;

            // Figure out today and tomorrow's day entries
            const today = new Date();
            const tomorrow = new Date(today.getTime() + 86400000);
            const todayDate = today.getDate();
            const tomorrowDate = tomorrow.getDate();

            // Match by checking if date string contains the day number as a word boundary
            const todayDay = (data.days || []).find(d => d.date && d.date.split(' ').map(Number).includes(todayDate));
            const tomorrowDay = (data.days || []).find(d => d.date && d.date.split(' ').map(Number).includes(tomorrowDate));

            // Build status display with transitions
            const todayStatus = todayDay ? shortStatusClock(todayDay.status) : shortStatusClock(data.status);
            const todayIcons = todayDay ? hazardIconsClock(todayDay.hazards) : '';
            const tomorrowStatus = tomorrowDay ? shortStatusClock(tomorrowDay.status) : 'NORMAL';
            const tomorrowIcons = tomorrowDay ? hazardIconsClock(tomorrowDay.hazards) : '';

            // Build today display with transitions
            // e.g. "NORMAL → CWD 12Z ⚡🌊" or "CWD ⚡🔥 → EC 00Z ⚡"
            function buildTransitionStr(day) {
                if (!day || !day.transitions || !day.transitions.length) return null;
                return day.transitions.map(function(t) {
                    var ts = shortStatusClock(t.to);
                    // Get icons for destination status - use same day hazards for CWD/EC transitions
                    var tIcons = (ts !== 'NORMAL') ? hazardIconsClock(day.hazards) : '';
                    return '→ ' + ts + ' ' + t.at + (tIcons ? ' ' + tIcons : '');
                }).join(' ');
            }

            var todayTransition = buildTransitionStr(todayDay);
            var displayStatus = todayStatus + (todayIcons ? ' ' + todayIcons : '');
            if (todayTransition) displayStatus += ' ' + todayTransition;

            let tomorrowDisplay = '';
            if(tomorrowStatus !== 'NORMAL') {
                var tomorrowTransition = buildTransitionStr(tomorrowDay);
                tomorrowDisplay = ' | Tomorrow: ' + tomorrowStatus + (tomorrowIcons ? ' ' + tomorrowIcons : '');
                if (tomorrowTransition) tomorrowDisplay += ' ' + tomorrowTransition;
            }

            // Map to badge class
            let badgeClass = 'status-normal';
            if(todayStatus === 'CWD') badgeClass = 'status-critical';
            else if(todayStatus === 'EC') badgeClass = 'status-caution';

            // Tomorrow gets its own color class
            let tomorrowClass = 'status-normal';
            if(tomorrowStatus === 'CWD') tomorrowClass = 'status-critical';
            else if(tomorrowStatus === 'EC') tomorrowClass = 'status-caution';

            // Update both header badges
            ['nco-status-value', 'nco-status-value-nco'].forEach(id => {
                const el = document.getElementById(id);
                if(el) {
                    el.className = 'status-value-badge ' + badgeClass;
                    el.innerHTML = displayStatus + 
                        (tomorrowDisplay ? '<span class="status-value-badge ' + tomorrowClass + '" style="font-size:1em; margin-left:4px;">' + tomorrowDisplay + '</span>' : '');
                }
            });

            // Update modal selector to reflect current status
            const modalReadoutMenu = null; // NCO status selector removed
            if(modalReadoutMenu) {
                if(todayStatus === 'CWD') modalReadoutMenu.value = 'Critical Weather Day';
                else if(todayStatus === 'EC') modalReadoutMenu.value = 'Enhanced Caution';
                else modalReadoutMenu.value = 'NORMAL';
            }

            customFrameConfig.ncoStatus = data.status;
            try { localStorage.setItem('GLOBAL_NCO_STATUS', data.status); } catch(e) {}
        }
    } catch (e) {
        console.log("CWD status.json fetch failed, using cached value.", e);
        applyNCOStatusUI(customFrameConfig.ncoStatus || 'NORMAL');
    }
}

function applyNCOStatusUI(statusVal) {
    const stdHeaderBadge = document.getElementById('nco-status-value');
    const ncoHeaderBadge = document.getElementById('nco-status-value-nco');

