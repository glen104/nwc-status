function saveFIMICFromUI() {
    var fimic = {
        fimName:  (document.getElementById('nwc-fim-name')  || {}).value || '',
        fimStart: (document.getElementById('nwc-fim-start') || {}).value || '',
        fimEnd:   (document.getElementById('nwc-fim-end')   || {}).value || '',
        icName:   (document.getElementById('nwc-ic-name')   || {}).value || '',
        icStart:  (document.getElementById('nwc-ic-start')  || {}).value || '',
        icEnd:    (document.getElementById('nwc-ic-end')    || {}).value || ''
    };
    saveFIMIC(fimic);
    scheduleHydroDispatch();
}

function getStaffingPayload() {
    // Read from localStorage (forecasters) + DOM (lead/start/end)
    var shifts = getShifts();
    var domShifts = shifts.map(function(s, i) {
        var leadEl  = document.getElementById('nwc-shift-lead-' + i);
        var startEl = document.getElementById('nwc-shift-start-' + i);
        var endEl   = document.getElementById('nwc-shift-end-' + i);
        return {
            start:       startEl ? startEl.value : (s.start || ''),
            end:         endEl   ? endEl.value   : (s.end   || ''),
            lead:        leadEl  ? leadEl.value  : (s.lead  || ''),
            forecasters: s.forecasters || []
        };
    });
    // Don't save back - just use for dispatch

    var fimNameEl  = document.getElementById('nwc-fim-name');
    var fimStartEl = document.getElementById('nwc-fim-start');
    var fimEndEl   = document.getElementById('nwc-fim-end');
    var icNameEl   = document.getElementById('nwc-ic-name');
    var icStartEl  = document.getElementById('nwc-ic-start');
    var icEndEl    = document.getElementById('nwc-ic-end');

    var fimName  = fimNameEl  ? fimNameEl.value  : '';
    var fimStart = fimStartEl ? fimStartEl.value : '';
    var fimEnd   = fimEndEl   ? fimEndEl.value   : '';
    var icName   = icNameEl   ? icNameEl.value   : '';
    var icStart  = icStartEl  ? icStartEl.value  : '';
    var icEnd    = icEndEl    ? icEndEl.value     : '';

    return {
        shifts: domShifts,
        fim: fimName ? { name:fimName, start:fimStart, end:fimEnd } : null,
        ic:  icName  ? { name:icName,  start:icStart,  end:icEnd  } : null
    };
}
