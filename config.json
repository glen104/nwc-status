// Show/hide shift type + backup sections based on office type
function syncNonNWCSections() {
    var otype  = currentOfficeType();  // 'nwc' | 'rfc' | 'wfo' | 'nco' | 'owp'
    var isNWC  = (otype === 'nwc');
    var isRFC  = (otype === 'rfc');
    var isWFO  = (otype === 'wfo');

    // Custom shift types — all non-NWC offices
    var ctl = document.getElementById('custom-shift-types-section');
    if (ctl) ctl.style.display = isNWC ? 'none' : 'flex';

    // Basin list — RFC only
    var bas = document.getElementById('basin-list-section');
    if (bas) bas.style.display = isRFC ? 'flex' : 'none';

    // Backup relationships — WFO only (not NWC, not RFC)
    var bkp = document.getElementById('backup-section');
    if (bkp) bkp.style.display = isWFO ? 'flex' : 'none';

    // Forecast tabs — NWC and RFC get Tomorrow only (day2=Day3/Day4 hidden)
    // WFO gets all 3 tabs
    var tab2 = document.getElementById('forecast-tab-2');
    var tab3 = document.getElementById('forecast-tab-3');
    var panel2 = document.getElementById('forecast-panel-2');
    var panel3 = document.getElementById('forecast-panel-3');
    var showExtraDays = isWFO;
    if (tab2)   tab2.style.display   = showExtraDays ? '' : 'none';
    if (tab3)   tab3.style.display   = showExtraDays ? '' : 'none';
    if (panel2) panel2.style.display = showExtraDays ? 'block' : 'none';
    if (panel3) panel3.style.display = 'none';  // always start hidden

    if (!isNWC) {
        renderShiftTypesList();
        if (!isRFC) renderBackupLists();
    }
    if (isRFC) renderBasinListTags();
}
