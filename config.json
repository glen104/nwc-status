function update() {
    const realNow = new Date(Date.now() + networkOffset);
    const now = new Date(realNow.getTime() + (simOffsetHours * 3600000));
    const dateGroups = {}; 
    const heroSecondsFilterMode = customFrameConfig.showSeconds;
    
    zoneOrder.forEach(id => {
        if (!visibleTimeZones.includes(id)) return;
        
        const h12 = (id === 'z' ? false : !use24Hour);
        const timeOptions = { timeZone: zones[id], hour12: h12, hour: '2-digit', minute: '2-digit', second: '2-digit' };
        
        const heroTimeOptions = { ...timeOptions, hour12: (id === 'z' ? false : !use24Hour) };
        if (!heroSecondsFilterMode) {
            delete heroTimeOptions.second;
        }

        const tzParts = new Intl.DateTimeFormat('en-US', { timeZone: zones[id], timeZoneName: 'short' }).formatToParts(now);
        const tzAbbr = tzParts.find(p => p.type === 'timeZoneName').value;
        const dateStr = now.toLocaleDateString('en-US', { timeZone: zones[id], weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' }).toUpperCase();
        
        if (!dateGroups[dateStr]) dateGroups[dateStr] = [];
        dateGroups[dateStr].push(shortNames[id]);

        const heroColor = getHeroColor(id);
        const resolvedColor = (heroColor === 'var(--color-default)') ? '#ffffff' : heroColor;

        if (activeHeroZones.includes(id)) {
            const el = document.getElementById(`hero-${id}-t`);
            if (el) el.innerText = now.toLocaleTimeString('en-US', heroTimeOptions);
        }

        if (markers[id]) {
            const currentStringMinuteCheckToken = now.toLocaleTimeString('en-US', { ...timeOptions, second: undefined });
            
            if (lastTooltipMinutesCache[id] !== currentStringMinuteCheckToken) {
                lastTooltipMinutesCache[id] = currentStringMinuteCheckToken;
                
                markers[id].setTooltipContent(`<div class="tooltip-name" style="color:${resolvedColor}">${zoneNames[id]} (${tzAbbr})</div><div class="tooltip-time" style="color:${resolvedColor}">${currentStringMinuteCheckToken}</div>`);
            }
            
            const markerDomElement = markers[id].getElement();
            if (markerDomElement) {
                const markerInnerCircle = markerDomElement.querySelector('div');
                if (markerInnerCircle) markerInnerCircle.style.backgroundColor = resolvedColor;
            }
            
            const tooltipContainer = markers[id].getTooltip();
            if (tooltipContainer) {
                const tooltipDomElement = tooltipContainer.getElement();
                if (tooltipDomElement) {
                    tooltipDomElement.style.borderColor = (resolvedColor === '#ffffff') ? '#30363d' : resolvedColor;
                }
            }
        }

        const footTab = document.querySelector(`.tab.f-${id}`);
        if (footTab) {
            footTab.style.borderBottomColor = (heroColor === 'var(--color-default)') ? 'transparent' : resolvedColor;
            
            const footTitleTxt = document.getElementById(`foot-title-txt-${id}`);
            if (footTitleTxt) {
                footTitleTxt.innerText = zoneNames[id];
            }

            const logoImg = document.getElementById('tab-logo-' + id);
            if (logoImg) {
                logoImg.style.display = (activeHeroZones.includes(id) && (customFrameConfig.profile.includes("WFO") || customFrameConfig.profile.includes("RFC"))) ? "inline-block" : "none";
            }

            const footT = document.getElementById("f-" + id + "-t");
            if (footT) {
                footT.innerText = now.toLocaleTimeString('en-US', { ...timeOptions, second: undefined });
                footT.style.color = (heroColor === 'var(--color-default)') ? 'white' : resolvedColor;
            }
            document.getElementById("f-" + id + "-d").innerText = now.toLocaleDateString('en-US', { timeZone: zones[id], weekday: 'short', month: 'short', day: 'numeric' });
            document.getElementById("f-" + id + "-abbr").innerText = `(${tzAbbr})`;
        }
    });

    let headerHTML = "";
    Object.keys(dateGroups).sort((a, b) => new Date(a) - new Date(b)).forEach(date => { 
        headerHTML += `<div class="date-block"><div class="date-line">${date}</div><div class="date-zones">(${dateGroups[date].join(', ')})</div></div>`; 
    });
    document.getElementById("local-date-display").innerHTML = headerHTML;
}

