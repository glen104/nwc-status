// ── CLOCK PICKER ─────────────────────────────────────────────────────────────
var _clockTarget = null;   // the input element we're editing
var _clockHour   = 12;     // 1-12
var _clockMin    = 0;      // 0-59
var _clockAMPM   = 'AM';
var _clockPhase  = 'hour'; // 'hour' or 'minute'

function openClockPicker(inputEl) {
    _clockTarget = inputEl;
    // Parse existing value
    var val = (inputEl.value || '').trim();
    var parsed = parseTimeString(val);
    _clockHour = parsed.hour;
    _clockMin  = parsed.min;
    _clockAMPM = parsed.ampm;
    _clockPhase = 'hour';

    // Position picker near the input
    var rect = inputEl.getBoundingClientRect();
    var picker = document.getElementById('clock-picker');
    picker.style.display = 'flex';
    var top = rect.bottom + 6;
    var left = rect.left;
    // Keep within viewport
    if (left + 220 > window.innerWidth) left = window.innerWidth - 228;
    if (top + 340 > window.innerHeight) top = rect.top - 346;
    picker.style.top  = top + 'px';
    picker.style.left = left + 'px';

    // Show overlay
    document.getElementById('clock-picker-overlay').style.pointerEvents = 'all';

    renderClockFace();
    updateClockDisplay();
}

function closeClockPicker() {
    document.getElementById('clock-picker').style.display = 'none';
    document.getElementById('clock-picker-overlay').style.pointerEvents = 'none';
    _clockTarget = null;
}

function applyClockPicker() {
    if (!_clockTarget) { closeClockPicker(); return; }
    var h = _clockHour;
    var m = String(_clockMin).padStart(2, '0');
    _clockTarget.value = h + ':' + m + ' ' + _clockAMPM;
    // Fire oninput/onchange to save the value
    _clockTarget.dispatchEvent(new Event('input', {bubbles:true}));
    _clockTarget.dispatchEvent(new Event('change', {bubbles:true}));
    closeClockPicker();
}

function parseTimeString(s) {
    var h=12, m=0, ap='AM';
    var match = s.match(/(\d{1,2}):(\d{2})\s*(AM|PM)/i);
    if (match) {
        h = parseInt(match[1]); m = parseInt(match[2]); ap = match[3].toUpperCase();
        if (h === 0) { h = 12; ap = 'AM'; }
        if (h > 12) { h = h - 12; ap = 'PM'; }
    }
    return { hour: h, min: m, ampm: ap };
}

function setClockAMPM(ap) {
    _clockAMPM = ap;
    document.getElementById('clock-am-btn').classList.toggle('active', ap === 'AM');
    document.getElementById('clock-pm-btn').classList.toggle('active', ap === 'PM');
    updateClockDisplay();
}

function renderClockFace() {
    var face = document.getElementById('clock-face');
    // Remove existing numbers
    face.querySelectorAll('.clock-number').forEach(function(e){ e.remove(); });

    var isHour = (_clockPhase === 'hour');
    var count = isHour ? 12 : 12; // show 0,5,10...55 for minutes or 1-12 for hours
    var cx = 80, cy = 80, r = 62;

    document.getElementById('clock-picker-mode-label').innerText = isHour ? 'SELECT HOUR' : 'SELECT MINUTE';
    document.getElementById('clock-hour-hand').style.display = isHour ? 'block' : 'none';
    document.getElementById('clock-min-hand').style.display  = isHour ? 'none'  : 'block';

    for (var i = 0; i < 12; i++) {
        var val  = isHour ? (i === 0 ? 12 : i) : i * 5;
        var angle = (i / 12) * 2 * Math.PI - Math.PI/2;
        var x = cx + r * Math.cos(angle);
        var y = cy + r * Math.sin(angle);
        var num = document.createElement('div');
        num.className = 'clock-number' + (isHour && val === _clockHour ? ' selected' : '') +
                        (!isHour && val === (_clockMin - (_clockMin % 5)) ? ' selected' : '');
        num.innerText = isHour ? val : String(val).padStart(2,'0');
        num.style.left = x + 'px';
        num.style.top  = y + 'px';
        (function(v){ num.addEventListener('click', function(e){ e.stopPropagation(); selectClockValue(v); }); })(val);
        face.appendChild(num);
    }
    updateHandPosition();
}

function selectClockValue(val) {
    if (_clockPhase === 'hour') {
        _clockHour = val;
        _clockPhase = 'minute';
    } else {
        _clockMin = val;
        _clockPhase = 'hour'; // reset for next open
        applyClockPicker();
        return;
    }
    renderClockFace();
    updateClockDisplay();
}

function handleClockFaceClick(e) {
    var face = document.getElementById('clock-face');
    var rect = face.getBoundingClientRect();
    var x = e.clientX - rect.left - 80;
    var y = e.clientY - rect.top  - 80;
    var angle = Math.atan2(y, x) + Math.PI/2;
    if (angle < 0) angle += 2 * Math.PI;
    if (_clockPhase === 'hour') {
        var h = Math.round(angle / (2 * Math.PI / 12));
        if (h === 0) h = 12;
        selectClockValue(h);
    } else {
        var m = Math.round(angle / (2 * Math.PI / 60));
        if (m === 60) m = 0;
        selectClockValue(m);
    }
}

function updateHandPosition() {
    var face = document.getElementById('clock-face');
    var r = 52;
    if (_clockPhase === 'hour') {
        var angle = ((_clockHour % 12) / 12) * 360 - 90;
        document.getElementById('clock-hour-hand').style.transform =
            'rotate(' + (angle + 90) + 'deg) translateX(-50%)';
        document.getElementById('clock-hour-hand').style.left = '50%';
    } else {
        var angle = (_clockMin / 60) * 360 - 90;
        document.getElementById('clock-min-hand').style.transform =
            'rotate(' + (angle + 90) + 'deg) translateX(-50%)';
        document.getElementById('clock-min-hand').style.left = '50%';
    }
}

function updateClockDisplay() {
    var m = String(_clockMin).padStart(2,'0');
    document.getElementById('clock-time-display').innerText = _clockHour + ':' + m + ' ' + _clockAMPM;
}
// ── END CLOCK PICKER ──────────────────────────────────────────────────────────

function toggleMarkerPositions() {
    var body = document.getElementById('marker-positions-body');
    var btn  = document.getElementById('marker-pos-collapse-btn');
    var icon = document.getElementById('marker-pos-toggle-icon');
    if (!body) return;
    var hidden = body.style.display === 'none';
    body.style.display = hidden ? 'block' : 'none';
    if (btn)  btn.innerText  = hidden ? 'Hide' : 'Show';
    if (icon) icon.innerText = hidden ? '▼' : '▶';
}

function refreshCustomPositionsUI() {
    var grid = document.getElementById('custom-positions-grid');
    if (!grid) return;
    var mode = isPCMode ? 'pc' : 'sd';
    var positions = getMarkerPositions(mode);
    var note = document.getElementById('marker-pos-mode-note');
    if (note) note.innerHTML = isPCMode
        ? '<span style="color:#f0a000;">⬡ PC Mode:</span> <span style="color:#8b949e;">drag markers directly on the map — positions save locally only.</span>'
        : '<span style="color:#58c4f5;">⬡ Situation Display:</span> <span style="color:#8b949e;">enter coords here — saves to server on SAVE CACHE, loads on refresh for all users.</span>';

    grid.innerHTML = '';
    zoneOrder.forEach(function(id) {
        if (!markerData[id] || !visibleTimeZones.includes(id)) return;
        var custom = positions[id] || {};
        var defPos = markerData[id].pos;
        var lat = custom.lat !== undefined ? custom.lat : defPos[0];
        var lng = custom.lng !== undefined ? custom.lng : defPos[1];
        var hasCustom = !!positions[id];

        var cell = document.createElement('div');
        cell.style.cssText = 'background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:6px;padding:6px 8px;';
        cell.innerHTML =
            '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">' +
                '<span style="font-size:0.75rem;font-weight:700;color:' + (hasCustom ? '#58c4f5' : '#8b949e') + ';">' + (window.zoneNames ? zoneNames[id] : id).toUpperCase() + '</span>' +
                (hasCustom ? '<button onclick="resetOneMarker(\''+id+'\')" style="background:none;border:none;color:#cc3300;font-size:0.7rem;cursor:pointer;padding:0;">↺ Reset</button>' : '') +
            '</div>' +
            '<div style="display:flex;gap:4px;align-items:center;">' +
                '<input type="number" step="0.01" value="'+lat.toFixed(4)+'" placeholder="Lat" class="station-txt-input" style="flex:1;text-align:center;font-size:0.75rem;padding:3px;" oninput="applyCustomPos(\''+id+'\',\'lat\',parseFloat(this.value))">' +
                '<input type="number" step="0.01" value="'+lng.toFixed(4)+'" placeholder="Lng" class="station-txt-input" style="flex:1;text-align:center;font-size:0.75rem;padding:3px;" oninput="applyCustomPos(\''+id+'\',\'lng\',parseFloat(this.value))">' +
            '</div>';
        grid.appendChild(cell);
    });
}

function applyCustomPos(id, axis, value) {
    if (isNaN(value)) return;
    var mode = isPCMode ? 'pc' : 'sd';
    var positions = getMarkerPositions(mode);
    if (!positions[id]) positions[id] = { lat: markerData[id].pos[0], lng: markerData[id].pos[1] };
    positions[id][axis] = value;
    saveMarkerPositions(mode, positions);
    // Move marker on map immediately
    if (markers[id]) markers[id].setLatLng([positions[id].lat, positions[id].lng]);
    refreshCustomPositionsUI();
}

function resetOneMarker(id) {
    var mode = isPCMode ? 'pc' : 'sd';
    var positions = getMarkerPositions(mode);
    delete positions[id];
    saveMarkerPositions(mode, positions);
    if (markers[id]) markers[id].setLatLng(markerData[id].pos);
    refreshCustomPositionsUI();
}

function resetMarkerPositions() {
    var mode = isPCMode ? 'pc' : 'sd';
    if (!confirm('Reset all ' + (isPCMode ? 'PC' : 'Situation Display') + ' marker positions to default?')) return;
    saveMarkerPositions(mode, {});
    // Move all markers back to defaults
    Object.keys(markerData).forEach(function(id) {
        if (markers[id]) markers[id].setLatLng(markerData[id].pos);
    });
    refreshCustomPositionsUI();
}
// ── END CUSTOM MARKER POSITIONS UI ────────────────────────────────────────────

