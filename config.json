    setTimeout(function(){
        document.getElementById('change-password-form').style.display = 'none';
        statusEl.innerText = '';
        statusEl.style.color = '#8b949e';
    }, 2000);
}

// ── TOKEN ENCRYPTOR (mirrors encrypt_token.py logic) ─────────────────────────
async function encryptToken(plaintext, password) {
    try {
        var enc = new TextEncoder();
        var salt = crypto.getRandomValues(new Uint8Array(16));
        var iv   = crypto.getRandomValues(new Uint8Array(16));
        var keyMaterial = await crypto.subtle.importKey('raw', enc.encode(password), 'PBKDF2', false, ['deriveKey']);
        var key = await crypto.subtle.deriveKey(
            { name: 'PBKDF2', salt: salt, iterations: 100000, hash: 'SHA-256' },
            keyMaterial, { name: 'AES-CBC', length: 256 }, false, ['encrypt']
        );
        var ciphertext = await crypto.subtle.encrypt({ name: 'AES-CBC', iv: iv }, key, enc.encode(plaintext));
        var combined = new Uint8Array(salt.length + iv.length + ciphertext.byteLength);
        combined.set(salt, 0); combined.set(iv, 16); combined.set(new Uint8Array(ciphertext), 32);
        return btoa(String.fromCharCode.apply(null, combined));
    } catch(e) { return null; }
}
