function initSettings() {
    try {
        const saved = localStorage.getItem('owp_operational_v20');
        if (saved) {
            const data = JSON.parse(saved);
            
            if (data.visibleTimeZones) visibleTimeZones = data.visibleTimeZones;
            activeHeroZones = data.heroZones || ['ct', 'z', 'none']; 
            use24Hour = data.use24Hour ?? true; 
            isPCMode = data.isPCMode ?? false;
            owpLogoVisible = data.owpLogoVisible ?? true; 
            savedZoom = data.zoom ?? 3.34; 
            savedCenter = data.center || [38.5, -96.5];
            
            if (data.profile) customFrameConfig.profile = data.profile;
            if (data.nodeIdentifier) customFrameConfig.nodeIdentifier = data.nodeIdentifier;
            if (data.showSeconds !== undefined) customFrameConfig.showSeconds = data.showSeconds;
            if (data.slotColors) customFrameConfig.slotColors = data.slotColors;
            if (data.homeGPS) customFrameConfig.homeGPS = data.homeGPS;
            if (data.homeTZ) customFrameConfig.homeTZ = data.homeTZ;
            if (data.ncoStatus) customFrameConfig.ncoStatus = data.ncoStatus;
            // Override with global NCO status if set (universal across profiles)
            var globalNcoStatus = localStorage.getItem('GLOBAL_NCO_STATUS');
            if (globalNcoStatus) customFrameConfig.ncoStatus = globalNcoStatus;
            if (data.nwcOpsLevel) customFrameConfig.nwcOpsLevel = data.nwcOpsLevel;
            if (data.nwcOpsHours) customFrameConfig.nwcOpsHours = data.nwcOpsHours;
            if (data.nwcOpsOpen)  customFrameConfig.nwcOpsOpen  = data.nwcOpsOpen;
            if (data.nwcOpsClose) customFrameConfig.nwcOpsClose = data.nwcOpsClose;
            // dispatchToken not loaded from storage - comes from config.json decrypt
            if (data.nwcOpsReason) customFrameConfig.nwcOpsReason = data.nwcOpsReason;

            document.getElementById('modal-time-toggle').checked = use24Hour;
            document.getElementById('mode-toggle').checked = isPCMode;
            document.getElementById('owp-logo-toggle').checked = owpLogoVisible;
            document.getElementById('seconds-toggle').checked = customFrameConfig.showSeconds;
            document.getElementById('profile-selector').value = customFrameConfig.profile;
            document.getElementById('station-identifier').value = customFrameConfig.nodeIdentifier;
            // NCO status is auto-scraped only - no manual selector
            document.getElementById('nwc-ops-level-selector').value = customFrameConfig.nwcOpsLevel;
            document.getElementById('nwc-ops-reason-input').value = customFrameConfig.nwcOpsReason;
            if (customFrameConfig.dispatchToken) {
                document.getElementById('dispatch-token-input').value = customFrameConfig.dispatchToken;
            }
            // Load hours settings
            var hoursMode = customFrameConfig.nwcOpsHours || 'default';
            var hoursDefaultEl = document.getElementById('nwc-hours-default');
            var hours24El      = document.getElementById('nwc-hours-24hr');
            var customDiv      = document.getElementById('nwc-hours-custom');
            if (hoursDefaultEl) hoursDefaultEl.checked = (hoursMode === 'default');
            if (hours24El)      hours24El.checked      = (hoursMode === '24hr');
            if (customDiv) {
                customDiv.style.display = (hoursMode === 'custom') ? 'flex' : 'none';
                document.getElementById('nwc-hours-open').value  = customFrameConfig.nwcOpsOpen  || '5:00 AM';
                document.getElementById('nwc-hours-close').value = customFrameConfig.nwcOpsClose || '8:30 PM';
            }
            // Sync config from checkbox state in case localStorage is stale
            handleHoursChange();
            // Never persist password - always clear on load
            document.getElementById('wpod-password-input').value = '';
            
            if (customFrameConfig.nwcOpsLevel !== "Level 4") {
                document.getElementById('nwc-reason-input-container').style.display = "flex";
                var hc = document.getElementById('nwc-hours-container');
                if (hc) hc.style.display = "flex";
