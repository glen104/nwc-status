function addUpcomingShift(dayIdx) {
    var shifts = getShiftsByDay(dayIdx);
    shifts.push({ start: '', end: '', lead: '', forecasters: [] });
    saveShiftsByDay(dayIdx, shifts);
    if (dayIdx === 2) renderDay3Shifts();
    if (dayIdx === 3) renderDay4Shifts();
    scheduleHydroDispatch();
}

function renderDay3Shifts() { renderUpcomingDayShifts(2, 'nwc-day3-shifts-list'); }
function renderDay4Shifts() { renderUpcomingDayShifts(3, 'nwc-day4-shifts-list'); }

function renderUpcomingDayShifts(dayIdx, listElId) {
    var shifts = getShiftsByDay(dayIdx);
    var roster = getRoster();
    var opts = '<option value="">-- none --</option>' + roster.map(function(r){
        return '<option value="' + r.name + '">' + r.name + '</option>';
    }).join('');
    var el = document.getElementById(listElId);
    if (!el) return;
    el.innerHTML = '';
    shifts.forEach(function(s, i) {
        var row = document.createElement('div');
        row.style.cssText = 'display:flex;flex-direction:column;gap:4px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:6px;padding:8px;';
        row.innerHTML =
            '<div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">' +
                '<span style="font-size:0.75rem;color:#8b949e;min-width:50px;">Shift '+(i+1)+'</span>' +
                '<input type="text" value="'+(s.start||'')+'" placeholder="Start" class="station-txt-input" style="width:90px;text-align:center;" onfocus="openClockPicker(this)" onchange="saveUpcomingShiftField('+dayIdx+','+i+',\'start\',this.value)">' +
                '<span style="color:#ccc;font-size:0.8rem;">to</span>' +
                '<input type="text" value="'+(s.end||'')+'" placeholder="End" class="station-txt-input" style="width:90px;text-align:center;" onfocus="openClockPicker(this)" onchange="saveUpcomingShiftField('+dayIdx+','+i+',\'end\',this.value)">' +
                (shifts.length>1 ? '<button onclick="removeUpcomingShift('+dayIdx+','+i+')" style="background:none;border:none;color:#cc3300;cursor:pointer;margin-left:auto;">✕</button>' : '') +
            '</div>' +
            '<div style="display:flex;gap:6px;align-items:center;">' +
                '<span style="font-size:0.75rem;color:#8b949e;min-width:50px;">Lead:</span>' +
                '<select class="profile-select" style="flex:1;" onchange="saveUpcomingShiftField('+dayIdx+','+i+',\'lead\',this.value)">' + opts + '</select>' +
            '</div>';
        el.appendChild(row);
        var selects = row.querySelectorAll('select');
        if (selects.length) selects[selects.length-1].value = s.lead || '';
    });
}

function saveUpcomingShiftField(dayIdx, shiftIdx, field, value) {
    var shifts = getShiftsByDay(dayIdx);
    if (shifts[shiftIdx]) { shifts[shiftIdx][field] = value; saveShiftsByDay(dayIdx, shifts); scheduleHydroDispatch(); }
}
function removeUpcomingShift(dayIdx, shiftIdx) {
    var shifts = getShiftsByDay(dayIdx);
    shifts.splice(shiftIdx, 1);
    saveShiftsByDay(dayIdx, shifts);
    if (dayIdx === 2) renderDay3Shifts();
    if (dayIdx === 3) renderDay4Shifts();
    scheduleHydroDispatch();
}
