// ── HYDRO STATUS JSON WRITER ─────────────────────────────────────────────────
        function manualHydroUpdate() {
            var statusEl = document.getElementById('nwc-update-status');
            if (statusEl) statusEl.innerText = 'Sending...';

            // First fetch existing JSON to get any data not in localStorage
            fetch(currentStatusFileURL() + '?cb=' + Date.now())
                .then(function(r){ return r.ok ? r.json() : null; })
                .then(function(existing) {
                    var existingNwc = (existing && existing[customFrameConfig.officeJsonKey]) ? existing[customFrameConfig.officeJsonKey] : {};

                    // Merge UI data with existing JSON data
                    var uiStaffing = getStaffingPayload();

                    // If UI shifts have no names, use existing JSON shifts
                    var hasShiftData = uiStaffing.shifts && uiStaffing.shifts.some(function(s){
                        return s.lead || (s.forecasters && s.forecasters.length);
                    });
                    if (!hasShiftData && existingNwc.shifts) {
                        uiStaffing.shifts = existingNwc.shifts;
                    }

                    // If UI roster is empty, use existing JSON roster
                    var uiRoster = getRoster();
                    if (!uiRoster.length && existingNwc.roster && existingNwc.roster.length) {
                        uiRoster = existingNwc.roster;
                        saveRoster(uiRoster);
                    }

                    // If UI FIM is empty, keep existing
                    if (!uiStaffing.fim && existingNwc.fim) {
                        uiStaffing.fim = existingNwc.fim;
                    }
                    if (!uiStaffing.ic && existingNwc.ic) {
                        uiStaffing.ic = existingNwc.ic;
                    }

                    writeHydroStatusWithData(uiStaffing, uiRoster, function(ok) {
                        if (statusEl) {
                            statusEl.innerText = ok ? '✓ Status updated successfully' : '✗ Update failed - check console';
                            setTimeout(function(){ statusEl.innerText = ''; }, 4000);
                        }
                    });
                })
                .catch(function() {
                    // If fetch fails just send what we have
                    writeHydroStatus(function(ok) {
                        if (statusEl) {
                            statusEl.innerText = ok ? '✓ Status updated successfully' : '✗ Update failed - check console';
                            setTimeout(function(){ statusEl.innerText = ''; }, 4000);
                        }
                    });
                });
        }

        // ── HYDRO STATUS JSON WRITER ─────────────────────────────────────────────────
var lastWrittenHydroLevel = null;
var lastWrittenHydroReason = null;
var lastWrittenHydroHours = null;

var LEVEL_NAMES = {
    'Level 4': 'Level 4 (Normal Operations)',
    'Level 3': 'Level 3 (Enhanced Operations)',
    'Level 2': 'Level 2 (Partial Activation)',
    'Level 1': 'Level 1 (Full Activation)'
};


// ── DISPATCH HELPER ───────────────────────────────────────────────────────────
// Supports both GitLab pipeline trigger and GitHub repository_dispatch.
// Set window._GITLAB_TRIGGER_URL to switch to GitLab mode.
function dispatchHydroUpdate(token, payload, thenFn, catchFn) {
    if (window._GITLAB_TRIGGER_URL) {
        var form = new URLSearchParams();
        form.append('token', token);
        form.append('ref', 'main');
        Object.keys(payload).forEach(function(k) {
            form.append('variables[' + k.toUpperCase() + ']',
                typeof payload[k] === 'object' ? JSON.stringify(payload[k]) : String(payload[k]));
        });
        fetch(window._GITLAB_TRIGGER_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: form.toString()
        }).then(thenFn||function(){}).catch(catchFn||function(){});
    } else {
        fetch('https://api.github.com/repos/glen104/nwc-status-private/dispatches', {
            method: 'POST',
            headers: { 'Authorization': 'token ' + token, 'Accept': 'application/vnd.github.v3+json', 'Content-Type': 'application/json' },
            body: JSON.stringify({ event_type: 'hydro_status_update', client_payload: payload })
        }).then(thenFn||function(){}).catch(catchFn||function(){});
    }
}
// ── END DISPATCH HELPER ───────────────────────────────────────────────────────
function writeHydroStatusWithData(staffing, roster, callback) {
    var level  = LEVEL_NAMES[customFrameConfig.nwcOpsLevel] || customFrameConfig.nwcOpsLevel || 'Level 4 (Normal Operations)';
    var reason = customFrameConfig.nwcOpsReason || '';
    var hours  = getHoursString();
    var token  = customFrameConfig.dispatchToken || '';
    var oid    = customFrameConfig.officeId || 'NWCO';
    if (!token) { console.log('No dispatch token for:', oid); if(callback) callback(false); return; }

    var otype = currentOfficeType();

    // ── Split into two dispatches to stay under GitHub's 10KB client_payload limit ──
    // Call 1: Ops status — always small, fires immediately
    var statusPayload = {
        officeId: oid,
        opsLevel: level,
        reason:   reason,
        hours:    hours
    };

    // Call 2: Staffing detail — larger, fires right after
    var staffingPayload = {
        officeId:   oid,
        staffing:   staffing,
        tomorrow:   getTomorrowStaffingPayload(),
        roster:     roster
    };

    // RFC and WFO get QPF forecast
    if (otype === 'rfc' || otype === 'wfo') {
        staffingPayload.forecast = getForecastPayload();
    }

    // WFO gets extra days and backup
    if (otype === 'wfo') {
        staffingPayload.day3   = getDay3Shifts();
        staffingPayload.day4   = getDay4Shifts();
        staffingPayload.backup = getBackupData();
    }

    // Non-NWC get shift types
    if (otype !== 'nwc') {
        staffingPayload.shiftTypes = getCustomShiftTypes();
    }

    // Merge into single payload — if under 9KB send together, otherwise send status first then staffing
    var combined = Object.assign({}, statusPayload, staffingPayload);
    var combinedSize = JSON.stringify(combined).length;

    if (combinedSize <= 9000) {
        // Small enough — send as one dispatch
        var payload = combined;
        sendDispatch(payload, token, oid, level, reason, hours, callback);
    } else {
        // Too large — send status first, then staffing 500ms later
        console.log('Payload ' + combinedSize + ' bytes — splitting into two dispatches');
        sendDispatch(statusPayload, token, oid, level, reason, hours, null);
        setTimeout(function() {
            sendDispatch(staffingPayload, token, oid, null, null, null, callback);
        }, 500);
    }
}

function sendDispatch(payload, token, oid, level, reason, hours, callback) {
    var isGitLab = !!(window._GITLAB_TRIGGER_URL);
    var fetchOpts;
    if (isGitLab) {
        var form = new URLSearchParams();
        form.append('token', token);
        form.append('ref', 'main');
        Object.keys(payload).forEach(function(k) {
            form.append('variables[' + k.toUpperCase() + ']',
                typeof payload[k] === 'object' ? JSON.stringify(payload[k]) : String(payload[k]));
        });
        fetchOpts = {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: form.toString()
        };
        fetch(window._GITLAB_TRIGGER_URL, fetchOpts)
            .then(function(r) {
                if (r.status === 201 || r.status === 200) {
                    if (level) { lastWrittenHydroLevel = level; lastWrittenHydroReason = reason; lastWrittenHydroHours = hours; }
                    console.log('GitLab pipeline triggered for:', oid);
                    if (callback) callback(true);
                    refreshStatusPanelIfActive();
                } else { console.log('GitLab trigger failed:', r.status); if (callback) callback(false); }
            })
            .catch(function(e) { console.log('GitLab trigger error:', e); if (callback) callback(false); });
    } else {
        fetchOpts = {
            method: 'POST',
            headers: { 'Authorization': 'token ' + token, 'Accept': 'application/vnd.github.v3+json', 'Content-Type': 'application/json' },
            body: JSON.stringify({ event_type: 'hydro_status_update', client_payload: payload })
        };
        fetch('https://api.github.com/repos/glen104/nwc-status-private/dispatches', fetchOpts)
        .then(function(r) {
            if (r.status === 204) {
                if (level) { lastWrittenHydroLevel = level; lastWrittenHydroReason = reason; lastWrittenHydroHours = hours; }
                console.log('Dispatch OK for:', oid);
                if (callback) callback(true);
                refreshStatusPanelIfActive();
            } else {
                r.text().then(function(body) { console.log('Dispatch failed:', r.status, body); });
                if (callback) callback(false);
            }
        })
        .catch(function(e) { console.log('Dispatch error:', e); if (callback) callback(false); });
    }
}

function writeHydroStatus(callback) {
    var level  = LEVEL_NAMES[customFrameConfig.nwcOpsLevel] || customFrameConfig.nwcOpsLevel || 'Level 4 (Normal Operations)';
    var reason = customFrameConfig.nwcOpsReason || '';
    var hours  = getHoursString();
    if (level === lastWrittenHydroLevel && reason === lastWrittenHydroReason && hours === lastWrittenHydroHours) { if(callback) callback(true); return; }
    writeHydroStatusWithData(getStaffingPayload(), getRoster(), callback);
}
