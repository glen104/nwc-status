}
// Helper — returns status file URL for current office
function currentStatusFileURL() {
    // jsDelivr CDN — purged by workflow, updates within ~30s of dispatch
    // Fallback: GitHub Pages (10min cache)
    var ocfg = OFFICE_CONFIGS[customFrameConfig.officeId];
    var file = ocfg ? ocfg.statusFile : 'hydro-status.json';
