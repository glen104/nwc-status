<script>
/* ============================================================
   USER RETAINED ENTIRE CORE EXECUTION ENGINE
============================================================ */
const zones = { z: "UTC", ct: "America/Chicago", et: "America/New_York", mt: "America/Denver", pacific: "America/Los_Angeles", alaska: "America/Anchorage", hawaii: "Pacific/Honolulu", guam: "Pacific/Guam", pago: "Pacific/Pago_Pago", pr: "America/Puerto_Rico" };
const zoneNames = { z: "ZULU", ct: "CENTRAL", et: "EASTERN", mt: "MOUNTAIN", pacific: "PACIFIC", alaska: "ALASKA", hawaii: "HAWAII", guam: "GUAM", pago: "PAGO", pr: "PUERTO RICO" };
const shortNames = { z: "Z", ct: "CT", et: "ET", mt: "MT", pacific: "PT", alaska: "AK", hawaii: "HI", guam: "GUAM", pago: "PAGO", pr: "PR" };
const markerData = {
    guam:    { pos: [13.44,  -215.21] },
    pago:    { pos: [-14.27, -170.70] },
    hawaii:  { pos: [21.31,  -159.86] },
    alaska:  { pos: [58.21,  -148.90] },
    pacific: { pos: [34.00,  -118.33] },
    mt:      { pos: [39.84,  -104.6]  },
    ct:      { pos: [33.10,   -87.56] },
    et:      { pos: [39.2,    -77.03] },
    pr:      { pos: [18.22,   -66.59] }
};

// ── CUSTOM MARKER POSITIONS ───────────────────────────────────────────────────
// PC mode: local only. SD mode: local + dispatched to server on SAVE CACHE.
function getMarkerPositions(mode) {
    var key = (mode === 'pc') ? 'MARKER_POS_PC' : 'MARKER_POS_SD';
    try { return JSON.parse(localStorage.getItem(key) || '{}'); } catch(e) { return {}; }
}
function saveMarkerPositions(mode, positions) {
    var key = (mode === 'pc') ? 'MARKER_POS_PC' : 'MARKER_POS_SD';
    try { localStorage.setItem(key, JSON.stringify(positions)); } catch(e) {}
}
// Get effective position for a zone (custom overrides default)
function getEffectiveMarkerPos(id) {
    // Always return the default position for initial marker creation.
    // Custom positions are applied via setLatLng after markers are built.
    return markerData[id] ? markerData[id].pos : [0, 0];
}

// Apply saved custom positions to existing markers (call after rebuildUIContainers)
function applyCustomMarkerPositions() {
    var mode = isPCMode ? 'pc' : 'sd';
    var custom = getMarkerPositions(mode);
    Object.keys(custom).forEach(function(id) {
        if (markers[id] && custom[id] && custom[id].lat !== undefined) {
            markers[id].setLatLng([custom[id].lat, custom[id].lng]);
        }
    });
}
// ── END MARKER POSITIONS ──────────────────────────────────────────────────────

const zoneOrder = ['guam', 'pago', 'hawaii', 'alaska', 'pacific', 'mt', 'ct', 'et', 'pr', 'z'];

let networkOffset = 0; 
let markers = {};
let homeMarker = null;
let lastTooltipMinutesCache = {};

let visibleTimeZones = ['guam', 'pago', 'hawaii', 'alaska', 'pacific', 'mt', 'ct', 'et', 'pr', 'z'];
let activeHeroZones = ['ct', 'z', 'none'];
let use24Hour = true;
let isPCMode = false;
let owpLogoVisible = true;
const pcDefaultZoom = 3.1;
let savedZoom = 3.34;
let savedCenter = [38.5, -96.5];

// ── MULTI-OFFICE PROFILE REGISTRY ────────────────────────────────────────────
// officeType: 'nwc' | 'rfc' | 'wfo' | 'nco' | 'owp'
// statusFile: which JSON file holds this office's status data
// defaultPwd:  default password (short form — RFC suffix stripped, WFOs use call sign)
const OFFICE_CONFIGS = {
    'NWCO':  { name: 'NWC Operations',             visualProfile: 'NWC',     jsonKey: 'nwc',    nodeId: 'NWC OPERATIONS',          defaultHours: '5:00 AM - 8:30 PM CT', officeType: 'nwc', statusFile: 'hydro-status.json',  defaultPwd: 'WPOD'  },
    'OWP':   { name: 'Office of Water Prediction', visualProfile: 'OWP',     jsonKey: 'owp',    nodeId: '',                        defaultHours: '8:00 AM - 5:00 PM CT', officeType: 'owp', statusFile: 'hydro-status.json',  defaultPwd: 'OWP'   },
    'NCO':   { name: 'NCEP Central Operations',    visualProfile: 'NCO',     jsonKey: 'nco',    nodeId: '',                        defaultHours: '24-Hour Operations',   officeType: 'nco', statusFile: 'nco-status.json',    defaultPwd: 'NCO'   },
    'LUB':   { name: 'WFO Lubbock',                visualProfile: 'WFO',     jsonKey: 'lub',    nodeId: 'LUB',   defaultHours: '24-Hour Operations',   officeType: 'wfo', statusFile: 'sr-status.json',     defaultPwd: 'LUB'   },
    'OUN':   { name: 'WFO Norman',                 visualProfile: 'WFO',     jsonKey: 'oun',    nodeId: 'OUN',   defaultHours: '24-Hour Operations',   officeType: 'wfo', statusFile: 'sr-status.json',     defaultPwd: 'OUN'   },
    'ABRFC': { name: 'Arkansas-Red Basin RFC',      visualProfile: 'RFC_OWP', jsonKey: 'abrfc',  nodeId: 'AB',   defaultHours: '8:00 AM - 5:00 PM CT', officeType: 'rfc', statusFile: 'hydro-status.json',  defaultPwd: 'AB'    },
    'AKRFC': { name: 'Alaska RFC',                  visualProfile: 'RFC_OWP', jsonKey: 'akrfc',  nodeId: 'AK',   defaultHours: '8:00 AM - 5:00 PM CT', officeType: 'rfc', statusFile: 'hydro-status.json',  defaultPwd: 'AK'    },
    'CBRFC': { name: 'Colorado Basin RFC',           visualProfile: 'RFC_OWP', jsonKey: 'cbrfc',  nodeId: 'CB',   defaultHours: '8:00 AM - 5:00 PM CT', officeType: 'rfc', statusFile: 'hydro-status.json',  defaultPwd: 'CB'    },
    'CNRFC': { name: 'California-Nevada RFC',        visualProfile: 'RFC_OWP', jsonKey: 'cnrfc',  nodeId: 'CN',   defaultHours: '8:00 AM - 5:00 PM CT', officeType: 'rfc', statusFile: 'hydro-status.json',  defaultPwd: 'CN'    },
    'LMRFC': { name: 'Lower Mississippi RFC',        visualProfile: 'RFC_OWP', jsonKey: 'lmrfc',  nodeId: 'LM',   defaultHours: '8:00 AM - 5:00 PM CT', officeType: 'rfc', statusFile: 'hydro-status.json',  defaultPwd: 'LM'    },
