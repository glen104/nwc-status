function handleHoursChange() {
    var defaultEl = document.getElementById('nwc-hours-default');
    var hr24El    = document.getElementById('nwc-hours-24hr');
    var customDiv = document.getElementById('nwc-hours-custom');
    if (!defaultEl || !hr24El || !customDiv) return;

    var isDefault = defaultEl.checked;
    var is24hr    = hr24El.checked;

    // Mutual exclusion - whichever was just clicked wins
    if (isDefault) {
        hr24El.checked = false;
        customDiv.style.display = 'none';
        customFrameConfig.nwcOpsHours = 'default';
    } else if (is24hr) {
        defaultEl.checked = false;
        customDiv.style.display = 'none';
        customFrameConfig.nwcOpsHours = '24hr';
    } else {
        // Neither checked - show custom fields
        customDiv.style.display = 'flex';
        customFrameConfig.nwcOpsHours = 'custom';
        customFrameConfig.nwcOpsOpen  = document.getElementById('nwc-hours-open').value  || '5:00 AM';
        customFrameConfig.nwcOpsClose = document.getElementById('nwc-hours-close').value || '8:30 PM';
    }
    saveSettings();
    scheduleHydroDispatch();
}

function getHoursString() {
    // Auto-detect CST vs CDT
    var now = new Date();
    var jan = new Date(now.getFullYear(), 0, 1);
    var jul = new Date(now.getFullYear(), 6, 1);
    var isDST = now.getTimezoneOffset() < Math.max(jan.getTimezoneOffset(), jul.getTimezoneOffset());
    var tzLabel = isDST ? 'CDT' : 'CST';

    if (customFrameConfig.nwcOpsHours === '24hr') {
        return '24-Hour Operations';
    } else if (customFrameConfig.nwcOpsHours === 'custom') {
        var open  = customFrameConfig.nwcOpsOpen  || '5:00 AM';
        var close = customFrameConfig.nwcOpsClose || '8:30 PM';
        return open + ' - ' + close + ' ' + tzLabel;
    } else {
        return '5:00 AM - 8:30 PM ' + tzLabel;
    }
}

