async function submitPasswordChange() {
    var curPass  = document.getElementById('current-password-input').value.trim();
    var newPass  = document.getElementById('new-password-input').value.trim();
    var confPass = document.getElementById('confirm-password-input').value.trim();
    var statusEl = document.getElementById('change-password-status');

    if (!curPass)             { statusEl.innerText = '✗ Enter your current password.'; return; }
    if (!newPass)             { statusEl.innerText = '✗ New password cannot be empty.'; return; }
    if (newPass !== confPass) { statusEl.innerText = '✗ Passwords do not match.'; return; }

    var oid = customFrameConfig.officeId;
    var expected = getOfficePassword(oid);
    if (curPass !== expected) { statusEl.innerText = '✗ Current password is incorrect.'; return; }

    setOfficePassword(oid, newPass);
    statusEl.style.color = '#2ea84a';
