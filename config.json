// Auto-promote tomorrow at midnight if no overnight shift
function checkAutoPromoteTomorrow() {
    var tomorrow = getTomorrowShifts();
    if (!tomorrow.length) return;
    var now = new Date();
    var ctStr = now.toLocaleString('en-US', { timeZone: 'America/Chicago', hour: 'numeric', minute: '2-digit', hour12: false });
    var p = ctStr.match(/(\d+):(\d+)/);
    if (!p) return;
    var h = parseInt(p[1]); var m = parseInt(p[2]);
    // Only check between midnight and 1 AM
    if (h !== 0) return;
    // Check if any current shift crosses midnight
    var todayShifts = getShifts();
    var hasOvernight = todayShifts.some(function(s) {
        var startMins = parseShiftTime(s.start);
        var endMins   = parseShiftTime(s.end);
        return endMins < startMins; // end before start = crosses midnight
    });
    if (!hasOvernight) {
        saveShifts(tomorrow);
        saveTomorrowShifts([]);
        console.log('Auto-promoted tomorrow shifts at midnight');
    }
}

function parseShiftTime(t) {
    if (!t) return -1;
    var m = t.toString().match(/(\d+):(\d+)\s*(AM|PM)/i);
    if (!m) return -1;
    var h = parseInt(m[1]); var mn = parseInt(m[2]); var ap = m[3].toUpperCase();
    if (ap === 'PM' && h !== 12) h += 12;
    if (ap === 'AM' && h === 12) h = 0;
    return h * 60 + mn;
}

// Check auto-promote every minute
setInterval(checkAutoPromoteTomorrow, 60000);
