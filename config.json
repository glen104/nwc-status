// ── OFFICE-SPECIFIC LABEL UPDATER ─────────────────────────────────────────────
function applyOfficeLabels() {
    var oid  = customFrameConfig.officeId || 'NWCO';
    var ocfg = OFFICE_CONFIGS[oid];
    var isNCO = (oid === 'NCO');

    // Ops level label — use short office name prefix
    var opsLabel = document.getElementById('ops-level-label');
    var opsBarLabel = document.getElementById('ops-level-bar-label');
    var opsBannerLabel = document.getElementById('ops-level-banner-label');
    var shortName = ocfg ? ocfg.name.toUpperCase() : 'OPS';
    // Use just the identifier part for the status bar (e.g. "OUN" not "WFO NORMAN")
    var barPrefix = oid;  // e.g. OUN, OHRFC, NCO
    if (opsLabel)       opsLabel.innerText       = shortName + ' Activation Level:';
    if (opsBarLabel)    opsBarLabel.innerText     = barPrefix + ' OPS LEVEL:';
    if (opsBannerLabel) opsBannerLabel.innerText  = barPrefix + ' OPS LEVEL:';

    // Default hours label
    var defLabel = document.getElementById('hours-default-label');
    var defHours = ocfg ? ocfg.defaultHours : '5:00 AM - 8:30 PM CT';
    if (defLabel) defLabel.innerText = 'Use Default (' + defHours + ')';

    // NCO toggle row — shown only for NCO
    var ncoRow  = document.getElementById('nco-ops-toggle-row');
    var levelRow = document.getElementById('nwc-ops-level-row');
    if (isNCO) {
        if (ncoRow) ncoRow.style.display = 'flex';
        var ncoEnabled = false;
        try { ncoEnabled = localStorage.getItem('NCO_OPS_ENABLED') === '1'; } catch(e) {}
        var cb = document.getElementById('nco-ops-enabled-checkbox');
        if (cb) cb.checked = ncoEnabled;
        if (levelRow) levelRow.style.display = ncoEnabled ? 'flex' : 'none';
    } else {
        if (ncoRow)   ncoRow.style.display  = 'none';
        if (levelRow) levelRow.style.display = 'flex';
    }
}
